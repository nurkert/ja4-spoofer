+static void ssl_ja4_write_csv_u16(FILE *file, const char *key,
+                                  Span<const uint16_t> values) {
+  fprintf(file, "%s=", key);
+  for (size_t i = 0; i < values.size(); i++) {
+    if (i != 0) {
+      fputc(',', file);
+    }
+    fprintf(file, "%u", static_cast<unsigned>(values[i]));
+  }
+  fputc('\n', file);
+}
+
+static void ssl_ja4_write_csv_u8(FILE *file, const char *key,
+                                 Span<const uint8_t> values) {
+  fprintf(file, "%s=", key);
+  for (size_t i = 0; i < values.size(); i++) {
+    if (i != 0) {
+      fputc(',', file);
+    }
+    fprintf(file, "%u", static_cast<unsigned>(values[i]));
+  }
+  fputc('\n', file);
+}
+
+static void ssl_ja4_write_csv_alpn(FILE *file, const char *key,
+                                   Span<const uint8_t> values) {
+  fprintf(file, "%s=", key);
+  size_t offset = 0;
+  bool first = true;
+  while (offset < values.size()) {
+    const size_t token_len = values[offset++];
+    if (offset + token_len > values.size()) {
+      break;
+    }
+    if (!first) {
+      fputc(',', file);
+    }
+    fwrite(values.data() + offset, 1, token_len, file);
+    offset += token_len;
+    first = false;
+  }
+  fputc('\n', file);
+}
+
+static const char *ssl_ja4_sni_mode_str(ssl_ja4_sni_mode_t mode) {
+  switch (mode) {
+    case ssl_ja4_sni_present:
+      return "present";
+    case ssl_ja4_sni_domain:
+      return "domain";
+    case ssl_ja4_sni_none:
+      return "none";
+    case ssl_ja4_sni_ip:
+      return "ip";
+    case ssl_ja4_sni_unset:
+      break;
+  }
+  return "unset";
+}
