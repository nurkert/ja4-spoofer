+void ssl_ja4_write_dump(SSL_HANDSHAKE *hs) {
+  const char *dump_path = getenv("BORINGSSL_JA4_DUMP");
+  if (dump_path == nullptr || *dump_path == '\0') {
+    return;
+  }
+
+  FILE *file = fopen(dump_path, "w");
+  if (file == nullptr) {
+    return;
+  }
+
+  fprintf(file, "# generated by boringssl ja4 runtime\n");
+  fprintf(file, "active=%d\n", hs->ja4.active ? 1 : 0);
+  fprintf(file, "apply_ok=%d\n", hs->ja4.apply_ok ? 1 : 0);
+  fprintf(file, "mismatch_mask=%u\n", hs->ja4.mismatch_mask);
+  fprintf(file, "effective_tls_min=%u\n", hs->min_version);
+  fprintf(file, "effective_tls_max=%u\n", hs->max_version);
+  fprintf(file, "strict=%d\n", hs->ja4.strict_enabled ? 1 : 0);
+  fprintf(file, "sni_mode=%s\n", ssl_ja4_sni_mode_str(hs->ja4.sni_mode));
+  fprintf(file, "enable_grease=%d\n", ssl_ja4_should_enable_grease(hs) ? 1 : 0);
+  fprintf(file, "enable_ch_xtn_permutation=%d\n",
+          hs->config->permute_extensions ? 1 : 0);
+  if (hs->ja4.grease_value_set && ssl_ja4_should_enable_grease(hs)) {
+    fprintf(file, "grease_value=%u\n", hs->ja4.grease_value);
+  } else {
+    fprintf(file, "grease_value=\n");
+  }
+
+  // requested_* block (Eingabe-Override aus BORINGSSL_JA4_CONFIG).  Schema
+  // order is fixed by docs/ja4-diagnostic-schema.md and must stay in sync
+  // across libraries.
+  ssl_ja4_write_csv_u16(file, "requested_cipher_suites", hs->ja4.cipher_suites);
+  ssl_ja4_write_csv_alpn(file, "requested_alpn", hs->ja4.alpn_wire);
+  ssl_ja4_write_csv_u16(file, "requested_signature_algorithms",
+                        hs->ja4.signature_algorithms);
+  ssl_ja4_write_csv_u16(file, "requested_extension_order",
+                        hs->ja4.extension_order);
+  ssl_ja4_write_csv_u16(file, "requested_supported_versions",
+                        hs->ja4.supported_versions);
+  ssl_ja4_write_csv_u16(file, "requested_supported_groups",
+                        hs->ja4.supported_groups);
+  ssl_ja4_write_csv_u16(file, "requested_key_share_groups",
+                        hs->ja4.key_share_groups);
+  ssl_ja4_write_csv_u8(file, "requested_psk_key_exchange_modes",
+                       hs->ja4.psk_key_exchange_modes);
+
+  // final_* block (re-parsed aus serialisiertem ClientHello).
+  ssl_ja4_write_csv_u16(file, "final_cipher_suites",
+                        hs->ja4.final_cipher_suites);
+  ssl_ja4_write_csv_alpn(file, "final_alpn", hs->ja4.final_alpn_wire);
+  ssl_ja4_write_csv_u16(file, "final_signature_algorithms",
+                        hs->ja4.final_signature_algorithms);
+  ssl_ja4_write_csv_u16(file, "final_extension_order",
+                        hs->ja4.final_extensions);
+  ssl_ja4_write_csv_u16(file, "final_supported_versions",
+                        hs->ja4.final_supported_versions);
+  ssl_ja4_write_csv_u16(file, "final_supported_groups",
+                        hs->ja4.final_supported_groups);
+  ssl_ja4_write_csv_u16(file, "final_key_share_groups",
+                        hs->ja4.final_key_share_groups);
+  ssl_ja4_write_csv_u8(file, "final_psk_key_exchange_modes",
+                       hs->ja4.final_psk_key_exchange_modes);
+
+  // lib_boringssl_* block: BoringSSL-specific extras outside the JA4 schema.
+  {
+    const uint8_t seed = hs->grease_seed[0];
+    const uint16_t grease_cipher =
+        static_cast<uint16_t>(((seed & 0xf0u) | 0x0au) * 0x101u);
+    fprintf(file, "lib_boringssl_effective_grease_cipher=0x%04x\n",
+            static_cast<unsigned>(grease_cipher));
+  }
+  if (hs->ja4.tls_min_set) {
+    fprintf(file, "lib_boringssl_requested_tls_min=%u\n", hs->ja4.tls_min);
+  }
+  if (hs->ja4.tls_max_set) {
+    fprintf(file, "lib_boringssl_requested_tls_max=%u\n", hs->ja4.tls_max);
+  }
+
+  fclose(file);
+}
