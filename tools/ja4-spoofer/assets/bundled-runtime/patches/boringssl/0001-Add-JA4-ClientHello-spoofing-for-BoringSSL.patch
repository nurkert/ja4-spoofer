+// Phase 2 parity helpers: force-emit and synthetic-extension constructor.
+//
+// JA4-config-driven ClientHello replay sometimes requires emitting extensions
+// that BoringSSL's native builders normally suppress (for example
+// |status_request| when no OCSP responder is configured) and extensions for
+// which BoringSSL has no native builder at all (for example
+// |record_size_limit| 0x001c). These helpers gate strictly on the JA4 config:
+// force-emit only triggers when the extension is explicitly listed in
+// |extension_order| and |extension_mode| is one of {exact, reorder}.
+static bool ssl_ja4_force_emit_enabled(const SSL_HANDSHAKE *hs,
+                                       uint16_t ext_type) {
+  if (!hs->ja4.active) {
+    return false;
+  }
+  if (hs->ja4.extension_mode != ssl_ja4_mode_exact &&
+      hs->ja4.extension_mode != ssl_ja4_mode_reorder) {
+    return false;
+  }
+  if (hs->ja4.extension_order.empty()) {
+    return false;
+  }
+  return ja4_array_contains_u16(hs->ja4.extension_order, ext_type);
