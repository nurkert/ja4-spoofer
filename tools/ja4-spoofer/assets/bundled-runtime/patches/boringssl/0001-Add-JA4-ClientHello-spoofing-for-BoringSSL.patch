+static std::string_view ja4_trim(std::string_view value) {
+  size_t begin = 0;
+  while (begin < value.size() && isspace(static_cast<unsigned char>(value[begin]))) {
+    begin++;
+  }
+  size_t end = value.size();
+  while (end > begin && isspace(static_cast<unsigned char>(value[end - 1]))) {
+    end--;
+  }
+  return value.substr(begin, end - begin);
+}
+
+static std::string ja4_to_lower(std::string_view value) {
+  std::string out;
+  out.reserve(value.size());
+  for (char c : value) {
+    out.push_back(static_cast<char>(tolower(static_cast<unsigned char>(c))));
+  }
+  return out;
+}
+
+static bool ja4_parse_bool(std::string_view value, bool *out) {
+  const std::string lowered = ja4_to_lower(ja4_trim(value));
+  if (lowered == "1" || lowered == "true" || lowered == "yes" ||
+      lowered == "on") {
+    *out = true;
+    return true;
+  }
+  if (lowered == "0" || lowered == "false" || lowered == "no" ||
+      lowered == "off") {
+    *out = false;
+    return true;
+  }
+  return false;
+}
+
+static bool ja4_parse_mode(std::string_view value, ssl_ja4_mode_t *out) {
+  const std::string lowered = ja4_to_lower(ja4_trim(value));
+  if (lowered == "reorder") {
+    *out = ssl_ja4_mode_reorder;
+    return true;
+  }
+  if (lowered == "exact") {
+    *out = ssl_ja4_mode_exact;
+    return true;
+  }
+  return false;
+}
+
+static bool ja4_parse_sni_mode(std::string_view value, ssl_ja4_sni_mode_t *out) {
+  const std::string lowered = ja4_to_lower(ja4_trim(value));
+  if (lowered == "present") {
+    *out = ssl_ja4_sni_present;
+    return true;
+  }
+  if (lowered == "domain") {
+    *out = ssl_ja4_sni_domain;
+    return true;
+  }
+  if (lowered == "none") {
+    *out = ssl_ja4_sni_none;
+    return true;
+  }
+  if (lowered == "ip") {
+    *out = ssl_ja4_sni_ip;
+    return true;
+  }
+  return false;
+}
+
+static bool ja4_parse_tls_version(std::string_view value, uint16_t *out) {
+  const std::string trimmed(ja4_trim(value));
+  if (trimmed == "1.0") {
+    *out = TLS1_VERSION;
+    return true;
+  }
+  if (trimmed == "1.1") {
+    *out = TLS1_1_VERSION;
+    return true;
+  }
+  if (trimmed == "1.2") {
+    *out = TLS1_2_VERSION;
+    return true;
+  }
+  if (trimmed == "1.3") {
+    *out = TLS1_3_VERSION;
+    return true;
+  }
+
+  char *end = nullptr;
+  const unsigned long parsed = strtoul(trimmed.c_str(), &end, 0);
+  if (end != nullptr && *end == '\0' && parsed <= UINT16_MAX) {
+    *out = static_cast<uint16_t>(parsed);
+    return true;
+  }
+
+  return false;
+}
+
+template <typename T>
+static bool ja4_copy_vector_to_array(const std::vector<T> &in, Array<T> *out) {
+  if (in.empty()) {
+    out->Reset();
+    return true;
+  }
+  return out->CopyFrom(Span<const T>(in.data(), in.size()));
+}
+
+static bool ja4_parse_csv_u16(std::string_view value, Array<uint16_t> *out) {
+  const std::string input(ja4_trim(value));
+  if (input.empty()) {
+    out->Reset();
+    return true;
+  }
+
+  std::vector<uint16_t> parsed;
+  size_t begin = 0;
+  while (begin <= input.size()) {
+    const size_t end = input.find(',', begin);
+    const size_t token_len =
+        (end == std::string::npos ? input.size() : end) - begin;
+    std::string_view token(input.data() + begin, token_len);
+    token = ja4_trim(token);
+    if (token.empty()) {
+      return false;
+    }
+
+    const std::string token_string(token);
+    char *tail = nullptr;
+    const unsigned long item = strtoul(token_string.c_str(), &tail, 0);
+    if (tail == nullptr || *tail != '\0' || item > UINT16_MAX) {
+      return false;
+    }
+    parsed.push_back(static_cast<uint16_t>(item));
+
+    if (end == std::string::npos) {
+      break;
+    }
+    begin = end + 1;
+  }
+
+  return ja4_copy_vector_to_array(parsed, out);
+}
+
+static bool ja4_parse_csv_u8(std::string_view value, Array<uint8_t> *out) {
+  const std::string input(ja4_trim(value));
+  if (input.empty()) {
+    out->Reset();
+    return true;
+  }
+
+  std::vector<uint8_t> parsed;
+  size_t begin = 0;
+  while (begin <= input.size()) {
+    const size_t end = input.find(',', begin);
+    const size_t token_len =
+        (end == std::string::npos ? input.size() : end) - begin;
+    std::string_view token(input.data() + begin, token_len);
+    token = ja4_trim(token);
+    if (token.empty()) {
+      return false;
+    }
+
+    const std::string token_string(token);
+    char *tail = nullptr;
+    const unsigned long item = strtoul(token_string.c_str(), &tail, 0);
+    if (tail == nullptr || *tail != '\0' || item > UINT8_MAX) {
+      return false;
+    }
+    parsed.push_back(static_cast<uint8_t>(item));
+
+    if (end == std::string::npos) {
+      break;
+    }
+    begin = end + 1;
+  }
+
+  return ja4_copy_vector_to_array(parsed, out);
+}
+
+static bool ja4_parse_alpn_wire(std::string_view value, Array<uint8_t> *out) {
+  const std::string input(ja4_trim(value));
+  if (input.empty()) {
+    out->Reset();
+    return true;
+  }
+
+  std::vector<uint8_t> wire;
+  size_t begin = 0;
+  while (begin <= input.size()) {
+    const size_t end = input.find(',', begin);
+    const size_t token_len =
+        (end == std::string::npos ? input.size() : end) - begin;
+    std::string_view token(input.data() + begin, token_len);
+    token = ja4_trim(token);
+    if (token.empty() || token.size() > UINT8_MAX ||
+        token.find(',') != std::string::npos) {
+      return false;
+    }
+    wire.push_back(static_cast<uint8_t>(token.size()));
+    wire.insert(wire.end(), token.begin(), token.end());
+
+    if (end == std::string::npos) {
+      break;
+    }
+    begin = end + 1;
+  }
+
+  return ja4_copy_vector_to_array(wire, out);
+}
+
+static bool ja4_array_contains_u16(Span<const uint16_t> values, uint16_t value) {
+  return std::find(values.begin(), values.end(), value) != values.end();
+}
+
+// ja4_is_grease_value: GREASE values per RFC 8701 follow the pattern 0x?A?A
+// (low nibble of each byte == 0xA, both bytes equal). The TLS 1.3 GREASE
+// table is {0x0A0A, 0x1A1A, ..., 0xFAFA}.
+static bool ja4_is_grease_value(uint16_t v) {
+  return ((v & 0x0F0F) == 0x0A0A) && ((v >> 8) == (v & 0xFF));
+}
+
+// ja4_arrays_equal_u16_modulo_grease: |b| (final-side wire reparse) may carry
+// extra GREASE entries that |a| (user-supplied requested list) does not. Strip
+// any GREASE-pattern entries from both before comparing. Used for the wire
+// shapes that mix in GREASE during serialization (cipher_suites,
+// supported_groups, supported_versions, key_share_groups).
+static bool ja4_arrays_equal_u16_modulo_grease(Span<const uint16_t> a,
+                                               Span<const uint16_t> b) {
+  std::vector<uint16_t> fa, fb;
+  fa.reserve(a.size());
+  fb.reserve(b.size());
+  for (uint16_t v : a) {
+    if (!ja4_is_grease_value(v)) {
+      fa.push_back(v);
+    }
+  }
+  for (uint16_t v : b) {
+    if (!ja4_is_grease_value(v)) {
+      fb.push_back(v);
+    }
+  }
+  return fa == fb;
+}
+
+static bool ja4_arrays_equal_u8(Span<const uint8_t> a,
+                                Span<const uint8_t> b) {
+  return a.size() == b.size() &&
+         std::equal(a.begin(), a.end(), b.begin());
+}
+
+static bool ja4_extension_lists_equal_modulo_psk(Span<const uint16_t> a,
+                                                 Span<const uint16_t> b) {
+  // Compare extension lists ignoring pre_shared_key (normalized to last
+  // position by the runtime), GREASE entries (added on the wire by the
+  // serializer for fingerprint diversity), and the trailing F5-padding
+  // extension (TLSEXT_TYPE_padding == 21) when it appears at the wire tail
+  // for the WebSphere/F5 bug workaround. Two lists are equivalent if they
+  // agree on order after these filters.
+  auto is_trailing_padding = [](Span<const uint16_t> list, size_t i) -> bool {
+    if (list[i] != TLSEXT_TYPE_padding) {
+      return false;
+    }
+    for (size_t j = i + 1; j < list.size(); j++) {
+      if (list[j] != TLSEXT_TYPE_padding && !ja4_is_grease_value(list[j])) {
+        return false;
+      }
+    }
+    return true;
+  };
+  auto filter = [&](Span<const uint16_t> in) -> std::vector<uint16_t> {
+    std::vector<uint16_t> out;
+    out.reserve(in.size());
+    for (size_t i = 0; i < in.size(); i++) {
+      uint16_t v = in[i];
+      if (v == TLSEXT_TYPE_pre_shared_key || ja4_is_grease_value(v)) {
+        continue;
+      }
+      if (is_trailing_padding(in, i)) {
+        continue;
+      }
+      out.push_back(v);
+    }
+    return out;
+  };
+  return filter(a) == filter(b);
+}
+
+static bool ja4_append_u16(Array<uint16_t> *values, uint16_t value) {
+  Array<uint16_t> next;
+  if (!next.InitForOverwrite(values->size() + 1)) {
+    return false;
+  }
+  if (!values->empty()) {
+    OPENSSL_memcpy(next.data(), values->data(), values->size() * sizeof(uint16_t));
+  }
+  next[values->size()] = value;
+  *values = std::move(next);
+  return true;
+}
+
+static bool ja4_append_u8(Array<uint8_t> *values, uint8_t value) {
+  Array<uint8_t> next;
+  if (!next.InitForOverwrite(values->size() + 1)) {
+    return false;
+  }
+  if (!values->empty()) {
+    OPENSSL_memcpy(next.data(), values->data(), values->size());
+  }
+  next[values->size()] = value;
+  *values = std::move(next);
+  return true;
+}
+
+static bool ja4_insert_u16_at(Array<uint16_t> *values, size_t index,
+                              uint16_t value) {
+  if (index > values->size()) {
+    index = values->size();
+  }
+
+  Array<uint16_t> next;
+  if (!next.InitForOverwrite(values->size() + 1)) {
+    return false;
+  }
+
+  for (size_t i = 0, src = 0; i < next.size(); i++) {
+    if (i == index) {
+      next[i] = value;
+      continue;
+    }
+    next[i] = (*values)[src++];
+  }
+  *values = std::move(next);
+  return true;
+}
+
+static bool ja4_find_u16_index(Span<const uint16_t> values, uint16_t needle,
+                               size_t *out_index) {
+  for (size_t i = 0; i < values.size(); i++) {
+    if (values[i] == needle) {
+      *out_index = i;
+      return true;
+    }
+  }
+  return false;
+}
+
+static bool ja4_remove_all_u16(Array<uint16_t> *values, uint16_t needle) {
+  size_t keep_count = 0;
+  for (uint16_t value : *values) {
+    if (value != needle) {
+      keep_count++;
+    }
+  }
+  if (keep_count == values->size()) {
+    return true;
+  }
+  Array<uint16_t> next;
+  if (!next.InitForOverwrite(keep_count)) {
+    return false;
+  }
+  size_t dst = 0;
+  for (uint16_t value : *values) {
+    if (value != needle) {
+      next[dst++] = value;
+    }
+  }
+  *values = std::move(next);
+  return true;
+}
+
+static bool ja4_dedupe_u16(Array<uint16_t> *values) {
+  if (values->size() < 2) {
+    return true;
+  }
+  std::vector<uint16_t> deduped;
+  deduped.reserve(values->size());
+  for (uint16_t value : *values) {
+    if (std::find(deduped.begin(), deduped.end(), value) == deduped.end()) {
+      deduped.push_back(value);
+    }
+  }
+  if (deduped.size() == values->size()) {
+    return true;
+  }
+  return ja4_copy_vector_to_array(deduped, values);
+}
+
+static void ssl_ja4_reset_config(SSLJA4Config *cfg) {
+  cfg->active = false;
+  cfg->strict_set = false;
+  cfg->strict_enabled = false;
+  cfg->tls_min_set = false;
+  cfg->tls_min = 0;
+  cfg->tls_max_set = false;
+  cfg->tls_max = 0;
+  cfg->cipher_suites.Reset();
+  cfg->cipher_mode = ssl_ja4_mode_none;
+  cfg->alpn_wire.Reset();
+  cfg->signature_algorithms.Reset();
+  cfg->supported_versions.Reset();
+  cfg->supported_groups.Reset();
+  cfg->key_share_groups.Reset();
+  cfg->psk_key_exchange_modes.Reset();
+  cfg->extension_order.Reset();
+  cfg->extension_mode = ssl_ja4_mode_none;
+  cfg->sni_mode = ssl_ja4_sni_unset;
+  cfg->grease_set = false;
+  cfg->grease_enabled = false;
+  cfg->grease_value_set = false;
+  cfg->grease_value = 0;
+  cfg->enable_ch_xtn_permutation_set = false;
+  cfg->enable_ch_xtn_permutation = false;
+  cfg->apply_ok = true;
+  cfg->mismatch_mask = 0;
+  cfg->parsed_once = false;
+  cfg->final_cipher_suites.Reset();
+  cfg->final_signature_algorithms.Reset();
+  cfg->final_extensions.Reset();
+  cfg->final_supported_versions.Reset();
+  cfg->final_supported_groups.Reset();
+  cfg->final_key_share_groups.Reset();
+  cfg->final_psk_key_exchange_modes.Reset();
+  cfg->synthetic_sent.Reset();
+}
+
+static bool ssl_ja4_require_extension(SSLJA4Config *cfg, uint16_t extension_type,
+                                      size_t insert_pos) {
+  if (ja4_array_contains_u16(cfg->extension_order, extension_type)) {
+    return true;
+  }
+  // Silently append the dependency in every mode. TLS 1.3 wire emission has
+  // mandatory deps the user can't reasonably opt out of (e.g. ALPN data is
+  // configured separately from extension_order; signature_algorithms has to
+  // ride alongside its values; psk_key_exchange_modes likewise). Treating a
+  // missing dep as drift would force fixtures to duplicate every implicit ID,
+  // which is the kind of cross-library churn we explicitly want to avoid.
+  return ja4_insert_u16_at(&cfg->extension_order, insert_pos, extension_type);
+}
+
+static bool ssl_ja4_normalize_psk_extension_position(SSLJA4Config *cfg) {
+  size_t first_psk_index = 0;
+  if (!ja4_find_u16_index(cfg->extension_order, TLSEXT_TYPE_pre_shared_key,
+                          &first_psk_index)) {
+    return true;
+  }
+  const bool already_last = first_psk_index + 1 == cfg->extension_order.size();
+  if (already_last) {
+    return true;
+  }
+  cfg->apply_ok = false;
+  cfg->mismatch_mask |= ssl_ja4_mismatch_invalid_config;
+  if (cfg->strict_enabled) {
+    return false;
+  }
+  if (!ja4_remove_all_u16(&cfg->extension_order, TLSEXT_TYPE_pre_shared_key)) {
+    return false;
+  }
+  return ja4_append_u16(&cfg->extension_order, TLSEXT_TYPE_pre_shared_key);
+}
+
+static bool ssl_ja4_normalize_extension_order(SSLJA4Config *cfg) {
+  if (cfg->extension_mode != ssl_ja4_mode_exact || cfg->extension_order.empty()) {
+    return true;
+  }
+
+  const size_t before_dedupe = cfg->extension_order.size();
+  if (!ja4_dedupe_u16(&cfg->extension_order)) {
+    return false;
+  }
+  if (cfg->extension_order.size() != before_dedupe) {
+    cfg->apply_ok = false;
+    cfg->mismatch_mask |= ssl_ja4_mismatch_invalid_config;
+    if (cfg->strict_enabled) {
+      return false;
+    }
+  }
+
+  if (!ssl_ja4_normalize_psk_extension_position(cfg)) {
+    return false;
+  }
+
+  if (cfg->sni_mode != ssl_ja4_sni_none && cfg->sni_mode != ssl_ja4_sni_ip &&
+      !ssl_ja4_require_extension(cfg, TLSEXT_TYPE_server_name, 0)) {
+    return false;
+  }
+
+  size_t sigalgs_index = 0;
+  const bool sigalgs_requested = ja4_find_u16_index(
+      cfg->extension_order, TLSEXT_TYPE_signature_algorithms, &sigalgs_index);
+
+  if (!cfg->alpn_wire.empty()) {
+    const size_t alpn_insert_pos =
+        sigalgs_requested ? sigalgs_index + 1 : cfg->extension_order.size();
+    if (!ssl_ja4_require_extension(
+            cfg, TLSEXT_TYPE_application_layer_protocol_negotiation,
+            alpn_insert_pos)) {
+      return false;
+    }
+  }
+
+  if (!cfg->signature_algorithms.empty() &&
+      !ssl_ja4_require_extension(cfg, TLSEXT_TYPE_signature_algorithms,
+                                 cfg->extension_order.size())) {
+    return false;
+  }
+  if ((!cfg->supported_groups.empty() || !cfg->key_share_groups.empty()) &&
+      !ssl_ja4_require_extension(cfg, TLSEXT_TYPE_supported_groups,
+                                 cfg->extension_order.size())) {
+    return false;
+  }
+  if (!cfg->key_share_groups.empty() &&
+      !ssl_ja4_require_extension(cfg, TLSEXT_TYPE_key_share,
+                                 cfg->extension_order.size())) {
+    return false;
+  }
+  if (!cfg->supported_versions.empty() &&
+      !ssl_ja4_require_extension(cfg, TLSEXT_TYPE_supported_versions,
+                                 cfg->extension_order.size())) {
+    return false;
+  }
+  // psk_key_exchange_modes auto-rides whenever the user supplied a non-empty
+  // modes list, mirroring OpenSSL/NSS behaviour. The 45 extension is always
+  // emitted with that data; reflecting the implicit ID in |extension_order|
+  // keeps requested/final byte-equal so cross-lib comparators agree.
+  if (!cfg->psk_key_exchange_modes.empty() &&
+      !ssl_ja4_require_extension(cfg, TLSEXT_TYPE_psk_key_exchange_modes,
+                                 cfg->extension_order.size())) {
+    return false;
+  }
+
+  if ((cfg->sni_mode == ssl_ja4_sni_none || cfg->sni_mode == ssl_ja4_sni_ip) &&
+      ja4_array_contains_u16(cfg->extension_order, TLSEXT_TYPE_server_name)) {
+    cfg->apply_ok = false;
+    cfg->mismatch_mask |= ssl_ja4_mismatch_missing_extension;
+    if (cfg->strict_enabled) {
+      return false;
+    }
+  }
+
+  return true;
+}
+
+static void ssl_ja4_parse_file(SSL_HANDSHAKE *hs, const char *path) {
+  FILE *file = fopen(path, "r");
+  if (file == nullptr) {
+    return;
+  }
+
+  SSLJA4Config *cfg = &hs->ja4;
+  char line[4096];
+  while (fgets(line, sizeof(line), file) != nullptr) {
+    std::string_view raw(line);
+    raw = ja4_trim(raw);
+    if (raw.empty() || raw[0] == '#') {
+      continue;
+    }
+
+    const size_t split = raw.find('=');
+    if (split == std::string::npos) {
+      continue;
+    }
+
+    const std::string key(ja4_trim(raw.substr(0, split)));
+    const std::string_view value = ja4_trim(raw.substr(split + 1));
+    if (key.empty()) {
+      continue;
+    }
+
+    bool ok = true;
+    bool unknown_key = false;
+    if (key == "strict") {
+      bool parsed = false;
+      ok = ja4_parse_bool(value, &parsed);
+      if (ok) {
+        cfg->strict_set = true;
+        cfg->strict_enabled = parsed;
+        cfg->active = true;
+      }
+    } else if (key == "tls_min") {
+      uint16_t parsed = 0;
+      ok = ja4_parse_tls_version(value, &parsed);
+      if (ok) {
+        cfg->tls_min_set = true;
+        cfg->tls_min = parsed;
+        cfg->active = true;
+      }
+    } else if (key == "tls_max") {
+      uint16_t parsed = 0;
+      ok = ja4_parse_tls_version(value, &parsed);
+      if (ok) {
+        cfg->tls_max_set = true;
+        cfg->tls_max = parsed;
+        cfg->active = true;
+      }
+    } else if (key == "cipher_suites") {
+      ok = ja4_parse_csv_u16(value, &cfg->cipher_suites);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "cipher_mode") {
+      ok = ja4_parse_mode(value, &cfg->cipher_mode);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "alpn") {
+      ok = ja4_parse_alpn_wire(value, &cfg->alpn_wire);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "signature_algorithms") {
+      ok = ja4_parse_csv_u16(value, &cfg->signature_algorithms);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "supported_versions") {
+      ok = ja4_parse_csv_u16(value, &cfg->supported_versions);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "supported_groups") {
+      ok = ja4_parse_csv_u16(value, &cfg->supported_groups);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "key_share_groups") {
+      ok = ja4_parse_csv_u16(value, &cfg->key_share_groups);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "psk_key_exchange_modes") {
+      ok = ja4_parse_csv_u8(value, &cfg->psk_key_exchange_modes);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "extension_order") {
+      ok = ja4_parse_csv_u16(value, &cfg->extension_order);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "extension_mode") {
+      ok = ja4_parse_mode(value, &cfg->extension_mode);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "sni_mode") {
+      ok = ja4_parse_sni_mode(value, &cfg->sni_mode);
+      if (ok) {
+        cfg->active = true;
+      }
+    } else if (key == "enable_grease") {
+      bool parsed = false;
+      ok = ja4_parse_bool(value, &parsed);
+      if (ok) {
+        cfg->grease_set = true;
+        cfg->grease_enabled = parsed;
+        cfg->active = true;
+      }
+    } else if (key == "enable_ch_xtn_permutation") {
+      bool parsed = false;
+      ok = ja4_parse_bool(value, &parsed);
+      if (ok) {
+        cfg->enable_ch_xtn_permutation_set = true;
+        cfg->enable_ch_xtn_permutation = parsed;
+        cfg->active = true;
+      }
+    } else if (key == "grease_value") {
+      uint16_t parsed = 0;
+      ok = ja4_parse_tls_version(value, &parsed);
+      if (ok) {
+        cfg->grease_value_set = true;
+        cfg->grease_value = parsed;
+        cfg->active = true;
+      }
+    } else {
+      ok = false;
+      unknown_key = true;
+    }
+
+    if (!ok) {
+      cfg->apply_ok = false;
+      cfg->mismatch_mask |= unknown_key ? ssl_ja4_mismatch_unknown_key
+                                        : ssl_ja4_mismatch_parse;
+      if (cfg->strict_set && cfg->strict_enabled) {
+        break;
+      }
+    }
+  }
+
+  fclose(file);
+}
+
+static bool ssl_ja4_validate_config(SSL_HANDSHAKE *hs) {
+  SSLJA4Config *cfg = &hs->ja4;
+  bool ok = true;
+
+  if (cfg->cipher_mode == ssl_ja4_mode_exact && cfg->cipher_suites.empty()) {
+    cfg->apply_ok = false;
+    cfg->mismatch_mask |= ssl_ja4_mismatch_invalid_config;
+    ok = false;
+  }
+
+  if (cfg->extension_mode == ssl_ja4_mode_exact &&
+      cfg->extension_order.empty()) {
+    cfg->apply_ok = false;
+    cfg->mismatch_mask |= ssl_ja4_mismatch_invalid_config;
+    ok = false;
+  }
+
+  if (cfg->tls_min_set && cfg->tls_max_set && cfg->tls_min > cfg->tls_max) {
+    cfg->apply_ok = false;
+    cfg->mismatch_mask |= ssl_ja4_mismatch_invalid_config;
+    ok = false;
+  }
+
+  return ok || !cfg->strict_enabled;
+}
+
+bool ssl_ja4_prepare_client_hello(SSL_HANDSHAKE *hs) {
+  ssl_ja4_reset_config(&hs->ja4);
+
+  const char *path = getenv("BORINGSSL_JA4_CONFIG");
+  if (path == nullptr || *path == '\0') {
+    path = getenv("NSS_JA4_CONFIG");
+  }
+  if (path == nullptr || *path == '\0') {
+    return true;
+  }
+
+  ssl_ja4_parse_file(hs, path);
+  hs->ja4.parsed_once = true;
+  if (!hs->ja4.active) {
+    return true;
+  }
+
+  if (!ssl_ja4_validate_config(hs)) {
+    return false;
+  }
+
+  if (!ssl_ja4_normalize_extension_order(&hs->ja4)) {
+    hs->ja4.apply_ok = false;
+    hs->ja4.mismatch_mask |= ssl_ja4_mismatch_apply;
+    return !hs->ja4.strict_enabled;
+  }
+
+  if (hs->ja4.tls_min_set) {
+    hs->min_version = hs->ja4.tls_min;
+  }
+  if (hs->ja4.tls_max_set) {
+    hs->max_version = hs->ja4.tls_max;
+  }
+  if (hs->min_version > hs->max_version) {
+    hs->ja4.apply_ok = false;
+    hs->ja4.mismatch_mask |= ssl_ja4_mismatch_apply;
+    if (hs->ja4.strict_enabled) {
+      return false;
+    }
+  }
+
+  if (!hs->ja4.alpn_wire.empty() &&
+      !hs->config->alpn_client_proto_list.CopyFrom(hs->ja4.alpn_wire)) {
+    return false;
+  }
+  if (!hs->ja4.signature_algorithms.empty() &&
+      !hs->config->verify_sigalgs.CopyFrom(hs->ja4.signature_algorithms)) {
+    return false;
+  }
+
+  if (!hs->ja4.supported_groups.empty()) {
+    Array<uint32_t> group_flags;
+    if (!group_flags.InitForOverwrite(hs->ja4.supported_groups.size())) {
+      return false;
+    }
+    OPENSSL_memset(group_flags.data(), 0, group_flags.size() * sizeof(uint32_t));
+    if (!hs->config->supported_group_list.CopyFrom(hs->ja4.supported_groups)) {
+      return false;
+    }
+    hs->config->supported_group_list_flags = std::move(group_flags);
+    hs->config->client_key_share_selections.reset();
+  }
+
+  if (!hs->ja4.key_share_groups.empty()) {
+    InplaceVector<uint16_t, kNumNamedGroups> selected;
+    for (uint16_t group_id : hs->ja4.key_share_groups) {
+      if (!ja4_array_contains_u16(hs->config->supported_group_list, group_id)) {
+        hs->ja4.apply_ok = false;
+        hs->ja4.mismatch_mask |= ssl_ja4_mismatch_key_shares;
+        if (hs->ja4.strict_enabled) {
+          return false;
+        }
+        continue;
+      }
+      if (std::find(selected.begin(), selected.end(), group_id) !=
+          selected.end()) {
+        continue;
+      }
+      if (!selected.TryPushBack(group_id)) {
+        return false;
+      }
+    }
+    if (!selected.empty()) {
+      hs->config->client_key_share_selections = std::move(selected);
+    }
+  } else if (!hs->ja4.supported_groups.empty()) {
+    InplaceVector<uint16_t, kNumNamedGroups> selected;
+    for (uint16_t group_id : hs->config->supported_group_list) {
+      if (SSLKeyShare::Create(group_id) == nullptr) {
+        continue;
+      }
+      if (!selected.TryPushBack(group_id)) {
+        return false;
+      }
+      break;
+    }
+    if (!selected.empty()) {
+      hs->config->client_key_share_selections = std::move(selected);
+    }
+  }
+
+  if (hs->ja4.enable_ch_xtn_permutation_set) {
+    hs->config->permute_extensions = hs->ja4.enable_ch_xtn_permutation;
+  }
+
+  // If grease_value is set, seed the GREASE RNG so all GREASE slots produce
+  // deterministic values derived from the requested value.  The formula in
+  // grease_index_to_value() is:
+  //   ret = (seed & 0xf0) | 0x0a;  ret |= ret << 8;
+  // so seed_byte = (grease_value >> 4) & 0xf0 yields the requested 0xωaωa.
+  if (hs->ja4.grease_value_set) {
+    // grease_index_to_value(): ret = (seed & 0xf0) | 0x0a; ret |= ret << 8.
+    // To reproduce 0xωaωa: seed_byte must satisfy (seed_byte & 0xf0) == ω<<4,
+    // so seed_byte = (grease_value >> 8) & 0xf0.
+    const uint8_t seed_byte =
+        static_cast<uint8_t>((hs->ja4.grease_value >> 8) & 0xf0);
+    OPENSSL_memset(hs->grease_seed, seed_byte, sizeof(hs->grease_seed));
+  }
+
+  if (hs->ja4.sni_mode == ssl_ja4_sni_none || hs->ja4.sni_mode == ssl_ja4_sni_ip) {
+    hs->ssl->hostname.reset();
+  } else if ((hs->ja4.sni_mode == ssl_ja4_sni_present ||
+              hs->ja4.sni_mode == ssl_ja4_sni_domain) &&
+             hs->ssl->hostname == nullptr) {
+    hs->ssl->hostname.reset(OPENSSL_strdup("example.com"));
+    if (hs->ssl->hostname == nullptr) {
+      return false;
+    }
+  }
+
+  return !hs->ja4.strict_enabled || hs->ja4.apply_ok;
+}
+
+bool ssl_ja4_should_enable_grease(const SSL_HANDSHAKE *hs) {
+  if (hs->ja4.active && hs->ja4.grease_set) {
+    return hs->ja4.grease_enabled;
+  }
+  return hs->ssl->ctx->grease_enabled;
+}
+
+// Standalone GREASE extension types (TLS extensions whose type itself is a
+// GREASE value, RFC 8701) are emitted only when JA4 is inactive, JA4 mode is
+// not exact, or the configured |extension_order| explicitly includes a GREASE
+// ID. Cross-lib parity requires exact-mode wire output to honor only the IDs
+// listed in the fixture, otherwise BoringSSL's CH adds GREASE markers that
+// drift the JA4 third hash from OpenSSL/NSS.
+bool ssl_ja4_should_emit_standalone_grease_extensions(
+    const SSL_HANDSHAKE *hs) {
+  if (!ssl_ja4_should_enable_grease(hs)) {
+    return false;
+  }
+  if (!hs->ja4.active || hs->ja4.extension_mode != ssl_ja4_mode_exact) {
+    return true;
+  }
+  for (uint16_t v : hs->ja4.extension_order) {
+    if ((v & 0x0F0F) == 0x0A0A && (v >> 8) == (v & 0xFF)) {
+      return true;
+    }
+  }
+  return false;
+}
+
+static bool ssl_ja4_is_extension_requested_exact(const SSL_HANDSHAKE *hs,
+                                                 uint16_t extension_type) {
+  if (!(hs->ja4.active && hs->ja4.extension_mode == ssl_ja4_mode_exact)) {
+    return true;
+  }
+  if (hs->ja4.extension_order.empty()) {
+    return true;
+  }
+  return ja4_array_contains_u16(hs->ja4.extension_order, extension_type);
+}
+
+void ssl_ja4_note_cipher(SSL_HANDSHAKE *hs, uint16_t cipher_id) {
+  (void)ja4_append_u16(&hs->ja4.final_cipher_suites, cipher_id);
+}
+
+void ssl_ja4_note_signature_algorithm(SSL_HANDSHAKE *hs, uint16_t sigalg_id) {
+  (void)ja4_append_u16(&hs->ja4.final_signature_algorithms, sigalg_id);
+}
+
+void ssl_ja4_note_extension(SSL_HANDSHAKE *hs, uint16_t extension_type) {
+  (void)ja4_append_u16(&hs->ja4.final_extensions, extension_type);
+}
+
+void ssl_ja4_note_supported_version(SSL_HANDSHAKE *hs, uint16_t version) {
+  (void)ja4_append_u16(&hs->ja4.final_supported_versions, version);
+}
+
+void ssl_ja4_note_supported_group(SSL_HANDSHAKE *hs, uint16_t group_id) {
+  (void)ja4_append_u16(&hs->ja4.final_supported_groups, group_id);
+}
+
+void ssl_ja4_note_keyshare_group(SSL_HANDSHAKE *hs, uint16_t group_id) {
+  (void)ja4_append_u16(&hs->ja4.final_key_share_groups, group_id);
+}
+
+void ssl_ja4_note_psk_mode(SSL_HANDSHAKE *hs, uint8_t mode) {
+  (void)ja4_append_u8(&hs->ja4.final_psk_key_exchange_modes, mode);
+}
+
+static void ssl_ja4_reset_final_notes(SSL_HANDSHAKE *hs) {
+  hs->ja4.final_cipher_suites.Reset();
+  hs->ja4.final_alpn_wire.Reset();
+  hs->ja4.final_signature_algorithms.Reset();
+  hs->ja4.final_extensions.Reset();
+  hs->ja4.final_supported_versions.Reset();
+  hs->ja4.final_supported_groups.Reset();
+  hs->ja4.final_key_share_groups.Reset();
+  hs->ja4.final_psk_key_exchange_modes.Reset();
+}
+
+void ssl_ja4_capture_client_hello(SSL_HANDSHAKE *hs, Span<const uint8_t> message) {
+  ssl_ja4_reset_final_notes(hs);
+  if (message.size() < SSL3_HM_HEADER_LENGTH || message[0] != SSL3_MT_CLIENT_HELLO) {
+    return;
+  }
+
+  size_t body_len = (static_cast<size_t>(message[1]) << 16) |
+                    (static_cast<size_t>(message[2]) << 8) |
+                    static_cast<size_t>(message[3]);
+  if (body_len + SSL3_HM_HEADER_LENGTH > message.size()) {
+    body_len = message.size() - SSL3_HM_HEADER_LENGTH;
+  }
+
+  CBS body;
+  CBS_init(&body, message.data() + SSL3_HM_HEADER_LENGTH, body_len);
+
+  uint16_t ignored_legacy_version;
+  CBS random, session_id, compression, cipher_suites;
+  if (!CBS_get_u16(&body, &ignored_legacy_version) ||
+      !CBS_get_bytes(&body, &random, SSL3_RANDOM_SIZE) ||
+      !CBS_get_u8_length_prefixed(&body, &session_id)) {
+    return;
+  }
+  if (SSL_is_dtls(hs->ssl)) {
+    CBS cookie;
+    if (!CBS_get_u8_length_prefixed(&body, &cookie)) {
+      return;
+    }
+  }
+  if (!CBS_get_u16_length_prefixed(&body, &cipher_suites) ||
+      !CBS_get_u8_length_prefixed(&body, &compression)) {
+    return;
+  }
+
+  while (CBS_len(&cipher_suites) >= 2) {
+    uint16_t cipher_id;
+    if (!CBS_get_u16(&cipher_suites, &cipher_id)) {
+      return;
+    }
+    ssl_ja4_note_cipher(hs, cipher_id);
+  }
+
+  if (CBS_len(&body) == 0) {
+    return;
+  }
+
+  CBS extensions;
+  if (!CBS_get_u16_length_prefixed(&body, &extensions)) {
+    return;
+  }
+  while (CBS_len(&extensions) > 0) {
+    uint16_t extension_type;
+    CBS extension_body;
+    if (!CBS_get_u16(&extensions, &extension_type) ||
+        !CBS_get_u16_length_prefixed(&extensions, &extension_body)) {
+      return;
+    }
+    ssl_ja4_note_extension(hs, extension_type);
+
+    if (extension_type == TLSEXT_TYPE_signature_algorithms) {
+      CBS sigalgs;
+      if (!CBS_get_u16_length_prefixed(&extension_body, &sigalgs)) {
+        continue;
+      }
+      while (CBS_len(&sigalgs) >= 2) {
+        uint16_t sigalg_id;
+        if (!CBS_get_u16(&sigalgs, &sigalg_id)) {
+          break;
+        }
+        ssl_ja4_note_signature_algorithm(hs, sigalg_id);
+      }
+    } else if (extension_type == TLSEXT_TYPE_supported_versions) {
+      CBS versions;
+      if (!CBS_get_u8_length_prefixed(&extension_body, &versions)) {
+        continue;
+      }
+      while (CBS_len(&versions) >= 2) {
+        uint16_t version;
+        if (!CBS_get_u16(&versions, &version)) {
+          break;
+        }
+        ssl_ja4_note_supported_version(hs, version);
+      }
+    } else if (extension_type == TLSEXT_TYPE_supported_groups) {
+      CBS groups;
+      if (!CBS_get_u16_length_prefixed(&extension_body, &groups)) {
+        continue;
+      }
+      while (CBS_len(&groups) >= 2) {
+        uint16_t group_id;
+        if (!CBS_get_u16(&groups, &group_id)) {
+          break;
+        }
+        ssl_ja4_note_supported_group(hs, group_id);
+      }
+    } else if (extension_type == TLSEXT_TYPE_key_share) {
+      CBS entries;
+      if (!CBS_get_u16_length_prefixed(&extension_body, &entries)) {
+        continue;
+      }
+      while (CBS_len(&entries) > 0) {
+        uint16_t group_id;
+        CBS key;
+        if (!CBS_get_u16(&entries, &group_id) ||
+            !CBS_get_u16_length_prefixed(&entries, &key)) {
+          break;
+        }
+        ssl_ja4_note_keyshare_group(hs, group_id);
+      }
+    } else if (extension_type == TLSEXT_TYPE_psk_key_exchange_modes) {
+      CBS modes;
+      if (!CBS_get_u8_length_prefixed(&extension_body, &modes)) {
+        continue;
+      }
+      while (CBS_len(&modes) > 0) {
+        uint8_t mode;
+        if (!CBS_get_u8(&modes, &mode)) {
+          break;
+        }
+        ssl_ja4_note_psk_mode(hs, mode);
+      }
+    } else if (extension_type ==
+               TLSEXT_TYPE_application_layer_protocol_negotiation) {
+      CBS protocol_list;
+      if (!CBS_get_u16_length_prefixed(&extension_body, &protocol_list)) {
+        continue;
+      }
+      // Capture the raw wire bytes (length-prefixed token list) so the
+      // diagnostic compare can match the same encoding that requested_alpn
+      // uses.
+      Array<uint8_t> alpn_copy;
+      if (alpn_copy.CopyFrom(
+              Span(CBS_data(&protocol_list), CBS_len(&protocol_list)))) {
+        hs->ja4.final_alpn_wire = std::move(alpn_copy);
+      }
+    }
+  }
+
+  if (!hs->ja4.active) {
+    return;
+  }
+
+  // Drift detection: compare requested_* vs final_* lists.  No apply-path
+  // change here -- the wire bytes have already been emitted; we only update
+  // the diagnostic mask so strict mode can hard-fail downstream and the dump
+  // reflects what actually went on the wire.
+  if (!hs->ja4.cipher_suites.empty() &&
+      !ja4_arrays_equal_u16_modulo_grease(hs->ja4.cipher_suites,
+                                          hs->ja4.final_cipher_suites)) {
+    hs->ja4.mismatch_mask |= ssl_ja4_mismatch_cipher_suites;
+    hs->ja4.apply_ok = false;
+  }
+  if (!hs->ja4.alpn_wire.empty() &&
+      !ja4_arrays_equal_u8(hs->ja4.alpn_wire, hs->ja4.final_alpn_wire)) {
+    hs->ja4.mismatch_mask |= ssl_ja4_mismatch_alpn;
+    hs->ja4.apply_ok = false;
+  }
+  if (!hs->ja4.signature_algorithms.empty() &&
+      !ja4_arrays_equal_u16_modulo_grease(
+          hs->ja4.signature_algorithms,
+          hs->ja4.final_signature_algorithms)) {
+    hs->ja4.mismatch_mask |= ssl_ja4_mismatch_signature_algorithms;
+    hs->ja4.apply_ok = false;
+  }
+  if (!hs->ja4.extension_order.empty() &&
+      !ja4_extension_lists_equal_modulo_psk(hs->ja4.extension_order,
+                                            hs->ja4.final_extensions)) {
+    hs->ja4.mismatch_mask |= ssl_ja4_mismatch_extension_order;
+    hs->ja4.apply_ok = false;
+  }
+  if (!hs->ja4.supported_groups.empty() &&
+      !ja4_arrays_equal_u16_modulo_grease(hs->ja4.supported_groups,
+                                          hs->ja4.final_supported_groups)) {
+    hs->ja4.mismatch_mask |= ssl_ja4_mismatch_supported_groups;
+    hs->ja4.apply_ok = false;
+  }
+  // The psk_key_exchange_modes value only rides extension 45. If 45 isn't in
+  // extension_order, the configured modes value is dead data — comparing it
