# Upstream source locations used when JA4 Spoofer runs from a packaged runtime
# bundle instead of a checked-out git repository with submodules. Version pins
# live in patches/<lib>/BASE_REF and in the source repo's submodule gitlinks.
OPENSSL_URL=https://github.com/openssl/openssl.git
BORINGSSL_URL=https://github.com/google/boringssl.git
NSS_URL=https://github.com/nss-dev/nss.git
JA4_URL=https://github.com/FoxIO-LLC/ja4.git
NGINX_URL=https://github.com/nginx/nginx.git
JA4_NGINX_MODULE_URL=https://github.com/FoxIO-LLC/ja4-nginx-module.git
