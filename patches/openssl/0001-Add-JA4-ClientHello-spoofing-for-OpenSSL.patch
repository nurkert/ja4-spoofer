+void ossl_ja4_write_dump(SSL_CONNECTION *s)
+{
+    const char *dump_path = ossl_safe_getenv("OPENSSL_JA4_DUMP");
+    FILE *fp = NULL;
+
+    ossl_ja4_finalize_mismatches();
+
+    if (dump_path == NULL || *dump_path == '\0')
+        return;
+
+    fp = fopen(dump_path, "w");
+    if (fp == NULL)
+        return;
+
+    /* Header / Status */
+    fprintf(fp, "active=%d\n", ossl_ja4_state.config.active);
+    fprintf(fp, "apply_ok=%d\n", ossl_ja4_state.apply_ok);
+    fprintf(fp, "mismatch_mask=%u\n",
+        (unsigned int)ossl_ja4_state.mismatch_mask);
+
+    /* Effektive Versionen + Knobs */
+    fprintf(fp, "effective_tls_min=%d\n", s->min_proto_version);
+    fprintf(fp, "effective_tls_max=%d\n", s->max_proto_version);
+    fprintf(fp, "strict=%d\n", ossl_ja4_state.config.strict_enabled);
+    fprintf(fp, "sni_mode=%s\n",
+        ossl_ja4_sni_mode_str(ossl_ja4_state.config.sni_mode));
+    fprintf(fp, "enable_grease=%d\n", ossl_ja4_state.config.grease_enabled);
+    /*
+     * enable_ch_xtn_permutation is part of the v1 schema. OpenSSL has no
+     * native ClientHello extension permutation, so the parser also sets
+     * 0x0020 (invalid_config_combination) when the value is 1. Emit the
+     * configured value (default 0) so the dump round-trips faithfully.
+     */
+    fprintf(fp, "enable_ch_xtn_permutation=%d\n",
+        ossl_ja4_state.config.enable_ch_xtn_permutation);
+    if (ossl_ja4_state.config.grease_enabled
+        && ossl_ja4_state.config.grease_value_set)
+        fprintf(fp, "grease_value=%u\n", ossl_ja4_state.config.grease_value);
+    else
+        fprintf(fp, "grease_value=\n");
+
+    /* requested_* Block */
+    ossl_ja4_write_csv_u16(fp, "requested_cipher_suites",
+        ossl_ja4_state.config.cipher_suites,
+        ossl_ja4_state.config.cipher_suites_len);
+    ossl_ja4_write_csv_alpn(fp, "requested_alpn",
+        ossl_ja4_state.config.alpn_wire,
+        ossl_ja4_state.config.alpn_wire_len);
+    ossl_ja4_write_csv_u16(fp, "requested_signature_algorithms",
+        ossl_ja4_state.config.signature_algorithms,
+        ossl_ja4_state.config.signature_algorithms_len);
+    ossl_ja4_write_csv_u16(fp, "requested_extension_order",
+        ossl_ja4_state.config.extension_order,
+        ossl_ja4_state.config.extension_order_len);
+    ossl_ja4_write_csv_u16(fp, "requested_supported_versions",
+        ossl_ja4_state.config.supported_versions,
+        ossl_ja4_state.config.supported_versions_len);
+    ossl_ja4_write_csv_u16(fp, "requested_supported_groups",
+        ossl_ja4_state.config.supported_groups,
+        ossl_ja4_state.config.supported_groups_len);
+    ossl_ja4_write_csv_u16(fp, "requested_key_share_groups",
+        ossl_ja4_state.config.key_share_groups,
+        ossl_ja4_state.config.key_share_groups_len);
+    ossl_ja4_write_csv_u8(fp, "requested_psk_key_exchange_modes",
+        ossl_ja4_state.config.psk_key_exchange_modes,
+        ossl_ja4_state.config.psk_key_exchange_modes_len);
+
+    /* final_* Block */
+    ossl_ja4_write_csv_u16(fp, "final_cipher_suites",
+        ossl_ja4_state.final_cipher_suites,
+        ossl_ja4_state.final_cipher_suites_len);
+    /* final_alpn is not re-parsed yet (phase 3 task); echo requested */
+    ossl_ja4_write_csv_alpn(fp, "final_alpn",
+        ossl_ja4_state.config.alpn_wire,
+        ossl_ja4_state.config.alpn_wire_len);
+    ossl_ja4_write_csv_u16(fp, "final_signature_algorithms",
+        ossl_ja4_state.final_signature_algorithms,
+        ossl_ja4_state.final_signature_algorithms_len);
+    ossl_ja4_write_csv_u16(fp, "final_extension_order",
+        ossl_ja4_state.final_extensions,
+        ossl_ja4_state.final_extensions_len);
+    ossl_ja4_write_csv_u16(fp, "final_supported_versions",
+        ossl_ja4_state.final_supported_versions,
+        ossl_ja4_state.final_supported_versions_len);
+    ossl_ja4_write_csv_u16(fp, "final_supported_groups",
+        ossl_ja4_state.final_supported_groups,
+        ossl_ja4_state.final_supported_groups_len);
+    ossl_ja4_write_csv_u16(fp, "final_key_share_groups",
+        ossl_ja4_state.final_key_share_groups,
+        ossl_ja4_state.final_key_share_groups_len);
+    ossl_ja4_write_csv_u8(fp, "final_psk_key_exchange_modes",
+        ossl_ja4_state.final_psk_key_exchange_modes,
+        ossl_ja4_state.final_psk_key_exchange_modes_len);
+
+    fclose(fp);
+}
+
+/*
+ * JA4 phase-3 post-serialization wire rewrite.
+ *
+ * Mirrors the NSS helper ssl3_Ja4RewriteTls13ExtensionBodies (patch 0005).
+ * After tls_construct_extensions has finished, the outer u24 ClientHello
+ * length is still open in |pkt| but every inner sub-packet (cipher_suites,
+ * legacy_compression_methods, the u16 extensions block) is closed and its
+ * length-prefix is already written to the underlying buffer. We can therefore
+ * parse the buffer in place, locate the extension list, and rewrite the
+ * bodies of selected extension types byte-for-byte.
+ *
+ * For now this only performs same-size rewrites for three simple lists:
+ *   - supported_versions (0x002b)
+ *   - supported_groups   (0x000a)
+ *   - psk_key_exchange_modes (0x002d)
+ * which keeps the total buffer length stable so we do not have to grow or
+ * shrink the WPACKET. Re-generating key_share entries (0x0033) requires a
+ * regenerated EVP_PKEY per group and is left as a known limit; if a
+ * key_share override is configured but this rewrite path cannot honour it,
+ * OSSL_JA4_MISMATCH_KEY_SHARES is raised so the strict-mode contract still
+ * surfaces the gap.
+ */
+
+#define OSSL_JA4_HEADER_BYTES 4
+
+static int ossl_ja4_wire_extension_offset(const unsigned char *body,
+    size_t body_len, size_t *ext_block_off, size_t *ext_block_len)
+{
+    size_t pos = 0;
+    size_t len;
+
+    /* legacy_version (2) + random (32) */
+    if (body_len < 2 + 32 + 1)
+        return 0;
+    pos = 2 + 32;
+
+    /* session_id <0..32> */
+    len = body[pos];
+    pos++;
+    if (len > 32 || pos + len > body_len)
+        return 0;
+    pos += len;
+
+    /* cipher_suites <2..2^16-2> */
+    if (pos + 2 > body_len)
+        return 0;
+    len = ((size_t)body[pos] << 8) | body[pos + 1];
+    pos += 2;
+    if (pos + len > body_len)
+        return 0;
+    pos += len;
+
+    /* legacy_compression_methods <1..2^8-1> */
+    if (pos + 1 > body_len)
+        return 0;
+    len = body[pos];
+    pos++;
+    if (pos + len > body_len)
+        return 0;
+    pos += len;
+
+    /* extensions <8..2^16-1> -- TLS 1.3 ClientHello must have extensions */
+    if (pos + 2 > body_len)
+        return 0;
+    len = ((size_t)body[pos] << 8) | body[pos + 1];
+    pos += 2;
+    if (pos + len != body_len)
+        return 0;
+
+    *ext_block_off = pos;
+    *ext_block_len = len;
+    return 1;
+}
+
+static int ossl_ja4_wire_find_extension(const unsigned char *block,
+    size_t block_len, uint16_t type, size_t *body_off, size_t *body_len)
+{
+    size_t pos = 0;
+
+    while (pos + 4 <= block_len) {
+        uint16_t this_type = ((uint16_t)block[pos] << 8) | block[pos + 1];
+        size_t this_len = ((size_t)block[pos + 2] << 8) | block[pos + 3];
+
+        if (pos + 4 + this_len > block_len)
+            return 0;
+        if (this_type == type) {
+            *body_off = pos + 4;
+            *body_len = this_len;
+            return 1;
+        }
+        pos += 4 + this_len;
+    }
+    return 0;
+}
+
+static int ossl_ja4_build_supported_versions_body(const OSSL_JA4_CONFIG *cfg,
+    unsigned char *out, size_t cap, size_t *out_len)
+{
+    size_t i;
+    size_t need;
+
+    if (cfg->supported_versions_len == 0)
+        return 0;
+    need = 1 + cfg->supported_versions_len * 2;
+    if (need > cap || cfg->supported_versions_len > 127)
+        return 0;
+    out[0] = (unsigned char)(cfg->supported_versions_len * 2);
+    for (i = 0; i < cfg->supported_versions_len; i++) {
+        out[1 + i * 2] = (unsigned char)(cfg->supported_versions[i] >> 8);
+        out[2 + i * 2] = (unsigned char)(cfg->supported_versions[i] & 0xff);
+    }
+    *out_len = need;
+    return 1;
+}
+
+static int ossl_ja4_build_supported_groups_body(const OSSL_JA4_CONFIG *cfg,
+    unsigned char *out, size_t cap, size_t *out_len)
+{
+    size_t i;
+    size_t list_bytes;
+    size_t need;
+
+    if (cfg->supported_groups_len == 0)
+        return 0;
+    list_bytes = cfg->supported_groups_len * 2;
+    need = 2 + list_bytes;
+    if (need > cap || list_bytes > 0xfffful)
+        return 0;
+    out[0] = (unsigned char)(list_bytes >> 8);
+    out[1] = (unsigned char)(list_bytes & 0xff);
+    for (i = 0; i < cfg->supported_groups_len; i++) {
+        out[2 + i * 2] = (unsigned char)(cfg->supported_groups[i] >> 8);
+        out[3 + i * 2] = (unsigned char)(cfg->supported_groups[i] & 0xff);
+    }
+    *out_len = need;
+    return 1;
+}
+
+static int ossl_ja4_build_psk_modes_body(const OSSL_JA4_CONFIG *cfg,
+    unsigned char *out, size_t cap, size_t *out_len)
+{
+    size_t i;
+    size_t need;
+
+    if (cfg->psk_key_exchange_modes_len == 0)
+        return 0;
+    need = 1 + cfg->psk_key_exchange_modes_len;
+    if (need > cap || cfg->psk_key_exchange_modes_len > 0xff)
+        return 0;
+    out[0] = (unsigned char)cfg->psk_key_exchange_modes_len;
+    for (i = 0; i < cfg->psk_key_exchange_modes_len; i++)
+        out[1 + i] = cfg->psk_key_exchange_modes[i];
+    *out_len = need;
+    return 1;
+}
+
+/*
+ * Replace one extension's body in-place if and only if the new body has the
+ * same size as the old body. Returns 1 if the rewrite happened, 0 if the
+ * extension is missing or the size differs (caller decides how to react).
+ */
+static int ossl_ja4_replace_extension_body_inplace(unsigned char *block,
+    size_t block_len, uint16_t type, const unsigned char *new_body,
+    size_t new_body_len)
+{
+    size_t body_off = 0;
+    size_t body_len = 0;
+
+    if (!ossl_ja4_wire_find_extension(block, block_len, type, &body_off,
+            &body_len))
+        return 0;
+    if (body_len != new_body_len)
+        return 0;
+    if (new_body_len > 0)
+        memcpy(block + body_off, new_body, new_body_len);
+    return 1;
+}
+
+/*
+ * Deterministic ClientHello extension permutation.
+ *
+ * Reorders the entire extension block in place using a Fisher-Yates shuffle
+ * driven by an xorshift32 PRNG seeded from |seed|. Same-size invariant is
+ * preserved (we only move whole (type, len, body) tuples — no body changes).
+ *
+ * RFC 8446 § 4.2.11 requires pre_shared_key (0x0029) to be the last
+ * extension. RFC 8446 § 4.2.10 keeps padding (0x0015) at the very end so it
+ * actually balances the ClientHello size; we treat it as a fixed-tail entry
+ * to avoid breaking any downstream length math (length re-balancing after
+ * permutation is documented as a sub-limit).
+ *
+ * Returns 1 on success, 0 on parse failure / OOM. Block contents are only
+ * touched when the function returns 1.
+ */
+#define OSSL_JA4_PERMUTE_MAX_EXTS 64
+
+typedef struct {
+    uint16_t type;
+    size_t off;
+    size_t total_len;
+} ossl_ja4_ext_entry;
+
+static int ossl_ja4_permute_extensions_inplace(unsigned char *block,
+    size_t block_len, uint32_t seed)
+{
+    ossl_ja4_ext_entry entries[OSSL_JA4_PERMUTE_MAX_EXTS];
+    size_t mid_idx[OSSL_JA4_PERMUTE_MAX_EXTS];
+    size_t tail_idx[2] = {0};
+    size_t n = 0, mid_n = 0, tail_n = 0;
+    size_t pos = 0, out_pos = 0;
+    size_t pad_pos = SIZE_MAX, psk_pos = SIZE_MAX;
+    unsigned char *scratch;
+    uint32_t s;
+    size_t i;
+
+    while (pos + 4 <= block_len) {
+        uint16_t type = ((uint16_t)block[pos] << 8) | block[pos + 1];
+        size_t len = ((size_t)block[pos + 2] << 8) | block[pos + 3];
+
+        if (pos + 4 + len > block_len)
+            return 0;
+        if (n >= OSSL_JA4_PERMUTE_MAX_EXTS)
+            return 0;
+        entries[n].type = type;
+        entries[n].off = pos;
+        entries[n].total_len = 4 + len;
+        if (type == TLSEXT_TYPE_padding)
+            pad_pos = n;
+        else if (type == TLSEXT_TYPE_psk)
+            psk_pos = n;
+        else
+            mid_idx[mid_n++] = n;
+        n++;
+        pos += 4 + len;
+    }
+    if (pos != block_len)
+        return 0;
+    if (n == 0)
+        return 1;
+
+    if (pad_pos != SIZE_MAX)
+        tail_idx[tail_n++] = pad_pos;
+    if (psk_pos != SIZE_MAX)
+        tail_idx[tail_n++] = psk_pos;
+
+    /*
+     * xorshift32. Seed normalisation guarantees a non-zero state so the PRNG
+     * actually produces a sequence — xorshift family stalls on zero.
+     */
+    s = seed;
+    if (s == 0)
+        s = 0x9e3779b9u;
+    s ^= s << 13;
+    s ^= s >> 17;
+    s ^= s << 5;
+
+    for (i = mid_n; i > 1; i--) {
+        size_t j;
+        size_t tmp_v;
+
+        s ^= s << 13;
+        s ^= s >> 17;
+        s ^= s << 5;
+        j = (size_t)(s % (uint32_t)i);
+        tmp_v = mid_idx[i - 1];
+        mid_idx[i - 1] = mid_idx[j];
+        mid_idx[j] = tmp_v;
+    }
+
+    scratch = OPENSSL_malloc(block_len);
+    if (scratch == NULL)
+        return 0;
+
+    for (i = 0; i < mid_n; i++) {
+        size_t src = entries[mid_idx[i]].off;
+        size_t cnt = entries[mid_idx[i]].total_len;
+
+        memcpy(scratch + out_pos, block + src, cnt);
+        out_pos += cnt;
+    }
+    for (i = 0; i < tail_n; i++) {
+        size_t src = entries[tail_idx[i]].off;
+        size_t cnt = entries[tail_idx[i]].total_len;
+
+        memcpy(scratch + out_pos, block + src, cnt);
+        out_pos += cnt;
+    }
+    if (out_pos != block_len) {
+        OPENSSL_free(scratch);
+        return 0;
+    }
+    memcpy(block, scratch, block_len);
+    OPENSSL_free(scratch);
+    return 1;
+}
+
+/*
+ * Mix the configured extension_order list down to a 32-bit seed so that
+ * permutation is reproducible even when grease_value is unset. Uses FNV-1a.
+ */
+static uint32_t ossl_ja4_extension_order_seed(const OSSL_JA4_CONFIG *cfg)
+{
+    uint32_t h = 0x811c9dc5u;
+    size_t i;
+
+    for (i = 0; i < cfg->extension_order_len; i++) {
+        h ^= (uint32_t)(cfg->extension_order[i] >> 8);
+        h *= 0x01000193u;
+        h ^= (uint32_t)(cfg->extension_order[i] & 0xffu);
+        h *= 0x01000193u;
+    }
+    return h;
+}
+
+/*
+ * Re-parse the on-wire bodies for the JA4-tracked TLS 1.3 fields and refresh
+ * the final_* state from the post-rewrite bytes. Mirrors the
+ * ssl3_Ja4SyncXtnDataFromBuffer / ssl_ja4_capture_client_hello path in NSS
+ * and BoringSSL.
+ */
+static void ossl_ja4_recapture_final_lists(const unsigned char *block,
+    size_t block_len)
+{
+    size_t body_off;
+    size_t body_len;
+
+    if (ossl_ja4_wire_find_extension(block, block_len,
+            TLSEXT_TYPE_supported_versions, &body_off, &body_len)
+        && body_len >= 1) {
+        size_t list_bytes = block[body_off];
+
+        if (list_bytes + 1 == body_len && (list_bytes & 1) == 0) {
+            size_t count = list_bytes / 2;
+            size_t i;
+
+            ossl_ja4_reset_dynamic(&ossl_ja4_state.final_supported_versions,
+                &ossl_ja4_state.final_supported_versions_len);
+            for (i = 0; i < count; i++) {
+                uint16_t v = ((uint16_t)block[body_off + 1 + i * 2] << 8)
+                    | block[body_off + 1 + i * 2 + 1];
+                ossl_ja4_append_u16(
+                    &ossl_ja4_state.final_supported_versions,
+                    &ossl_ja4_state.final_supported_versions_len, v);
+            }
+        }
+    }
+
+    if (ossl_ja4_wire_find_extension(block, block_len,
+            TLSEXT_TYPE_supported_groups, &body_off, &body_len)
+        && body_len >= 2) {
+        size_t list_bytes = ((size_t)block[body_off] << 8)
+            | block[body_off + 1];
+
+        if (list_bytes + 2 == body_len && (list_bytes & 1) == 0) {
+            size_t count = list_bytes / 2;
+            size_t i;
+
+            ossl_ja4_reset_dynamic(&ossl_ja4_state.final_supported_groups,
+                &ossl_ja4_state.final_supported_groups_len);
+            for (i = 0; i < count; i++) {
+                uint16_t v = ((uint16_t)block[body_off + 2 + i * 2] << 8)
+                    | block[body_off + 2 + i * 2 + 1];
+                ossl_ja4_append_u16(
+                    &ossl_ja4_state.final_supported_groups,
+                    &ossl_ja4_state.final_supported_groups_len, v);
+            }
+        }
+    }
+
+    if (ossl_ja4_wire_find_extension(block, block_len,
+            TLSEXT_TYPE_psk_kex_modes, &body_off, &body_len)
+        && body_len >= 1) {
+        size_t list_bytes = block[body_off];
+
+        if (list_bytes + 1 == body_len) {
+            size_t i;
+
+            OPENSSL_free(ossl_ja4_state.final_psk_key_exchange_modes);
+            ossl_ja4_state.final_psk_key_exchange_modes = NULL;
+            ossl_ja4_state.final_psk_key_exchange_modes_len = 0;
+            for (i = 0; i < list_bytes; i++)
+                ossl_ja4_note_psk_mode(block[body_off + 1 + i]);
+        }
+    }
+
+    if (ossl_ja4_wire_find_extension(block, block_len,
+            TLSEXT_TYPE_key_share, &body_off, &body_len)
+        && body_len >= 2) {
+        size_t list_bytes = ((size_t)block[body_off] << 8)
+            | block[body_off + 1];
+        size_t pos;
+
+        if (list_bytes + 2 == body_len) {
+            ossl_ja4_reset_dynamic(&ossl_ja4_state.final_key_share_groups,
+                &ossl_ja4_state.final_key_share_groups_len);
+            pos = body_off + 2;
+            while (pos + 4 <= body_off + body_len) {
+                uint16_t group = ((uint16_t)block[pos] << 8) | block[pos + 1];
+                size_t share_len = ((size_t)block[pos + 2] << 8)
+                    | block[pos + 3];
+
+                if (pos + 4 + share_len > body_off + body_len)
+                    break;
+                ossl_ja4_append_u16(
+                    &ossl_ja4_state.final_key_share_groups,
+                    &ossl_ja4_state.final_key_share_groups_len, group);
+                pos += 4 + share_len;
+            }
+        }
+    }
+}
+
+int ossl_ja4_rewrite_client_hello_wire(SSL_CONNECTION *s, WPACKET *pkt)
+{
+    OSSL_JA4_CONFIG *cfg = &ossl_ja4_state.config;
+    size_t total_written = 0;
+    unsigned char *buf;
+    unsigned char *body;
+    size_t body_len;
+    size_t ext_block_off = 0;
+    size_t ext_block_len = 0;
+    unsigned char *block;
+    int strict;
+    unsigned char tmp[1024];
+    size_t tmp_len = 0;
+
+    /* Inactive config: nothing to rewrite, success. */
+    if (!cfg->active)
+        return 1;
+
+    if (pkt == NULL || pkt->buf == NULL || pkt->buf->data == NULL)
+        return 1;
+
+    /*
+     * Make sure every closed sub-packet has its length written to the buffer.
+     * The outer u24 ClientHello sub is still open at this point but its
+     * length is recomputed implicitly from pkt->written - sub->pwritten when
+     * the statem write-loop calls WPACKET_finish, so we do not need to touch
+     * it here.
+     */
+    if (!WPACKET_fill_lengths(pkt))
+        return 1;
+
+    if (!WPACKET_get_total_written(pkt, &total_written))
+        return 1;
+    if (total_written <= OSSL_JA4_HEADER_BYTES)
+        return 1;
+
+    buf = (unsigned char *)pkt->buf->data;
+    body = buf + OSSL_JA4_HEADER_BYTES;
+    body_len = total_written - OSSL_JA4_HEADER_BYTES;
+
+    if (!ossl_ja4_wire_extension_offset(body, body_len, &ext_block_off,
+            &ext_block_len)) {
+        /* Likely TLS 1.2 ClientHello without extensions or malformed. */
+        return 1;
+    }
+
+    block = body + ext_block_off;
+    strict = ossl_ja4_state.config.strict_enabled
+        && ossl_ja4_state.config.strict_set;
+
+    /*
+     * Deterministic extension permutation (Chromium-style). Runs before the
+     * body rewrites so subsequent in-place edits still find their target by
+     * type lookup. Seed prefers the configured grease_value (matches the
+     * other Chromium-style spoofing knobs); if zero, fall back to a hash of
+     * the requested extension_order so the result is reproducible without
+     * GREASE.
+     */
+    if (cfg->enable_ch_xtn_permutation) {
+        uint32_t seed = (uint32_t)cfg->grease_value;
+
+        if (seed == 0)
+            seed = ossl_ja4_extension_order_seed(cfg);
+        if (!ossl_ja4_permute_extensions_inplace(block, ext_block_len,
+                seed)) {
+            ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_INVALID_CONFIG;
+            if (strict)
+                return 0;
+        }
+    }
+
+    if (cfg->supported_versions_len > 0
+        && ossl_ja4_build_supported_versions_body(cfg, tmp, sizeof(tmp),
+            &tmp_len)) {
+        if (!ossl_ja4_replace_extension_body_inplace(block, ext_block_len,
+                TLSEXT_TYPE_supported_versions, tmp, tmp_len)) {
+            /* Length mismatch -> cannot do same-size in-place rewrite. */
+            ossl_ja4_state.mismatch_mask
+                |= OSSL_JA4_MISMATCH_SUPPORTED_VERSIONS;
+            if (strict)
+                return 0;
+        }
+    }
+
+    if (cfg->supported_groups_len > 0
+        && ossl_ja4_build_supported_groups_body(cfg, tmp, sizeof(tmp),
+            &tmp_len)) {
+        if (!ossl_ja4_replace_extension_body_inplace(block, ext_block_len,
+                TLSEXT_TYPE_supported_groups, tmp, tmp_len)) {
+            ossl_ja4_state.mismatch_mask
+                |= OSSL_JA4_MISMATCH_SUPPORTED_GROUPS;
+            if (strict)
+                return 0;
+        }
+    }
+
+    if (cfg->psk_key_exchange_modes_len > 0
+        && ossl_ja4_build_psk_modes_body(cfg, tmp, sizeof(tmp), &tmp_len)) {
+        if (!ossl_ja4_replace_extension_body_inplace(block, ext_block_len,
+                TLSEXT_TYPE_psk_kex_modes, tmp, tmp_len)) {
+            ossl_ja4_state.mismatch_mask
+                |= OSSL_JA4_MISMATCH_PSK_KEX_MODES;
+            if (strict)
+                return 0;
+        }
+    }
+
+    /*
+     * key_share regeneration is a known limit of this iteration: it requires
+     * fresh EVP_PKEY material for each requested group which is non-trivial
+     * to splice in after tls_construct_extensions. If the caller asked for
+     * an explicit key_share_groups override we surface that as
+     * OSSL_JA4_MISMATCH_KEY_SHARES so strict mode rejects the handshake; the
+     * Phase-2 apply path already steered OpenSSL's internal key_share
+     * generation, so most JA4 replays still get the right wire bytes
+     * organically.
+     */
+    if (cfg->key_share_groups_len > 0) {
+        size_t ks_off = 0;
+        size_t ks_len = 0;
+
+        if (!ossl_ja4_wire_find_extension(block, ext_block_len,
+                TLSEXT_TYPE_key_share, &ks_off, &ks_len)) {
+            ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_KEY_SHARES;
+            if (strict)
+                return 0;
+        }
+    }
+
+    /* Re-capture final_* lists from the (possibly rewritten) wire bytes. */
+    ossl_ja4_recapture_final_lists(block, ext_block_len);
+
+    return 1;
+}
