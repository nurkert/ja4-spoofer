+#include <stdio.h>
+#include <string.h>
+#include <stdlib.h>
+#include <errno.h>
+
+#include "internal/cryptlib.h"
+#include <openssl/rand.h>
+#include "ssl_local.h"
+
+typedef enum {
+    OSSL_JA4_MODE_NONE = 0,
+    OSSL_JA4_MODE_REORDER_VAL = OSSL_JA4_MODE_REORDER,
+    OSSL_JA4_MODE_EXACT_VAL = OSSL_JA4_MODE_EXACT
+} OSSL_JA4_MODE;
+
+typedef enum {
+    OSSL_JA4_SNI_UNSET = 0,
+    OSSL_JA4_SNI_PRESENT,
+    OSSL_JA4_SNI_DOMAIN,
+    OSSL_JA4_SNI_NONE,
+    OSSL_JA4_SNI_IP
+} OSSL_JA4_SNI_MODE;
+
+typedef struct {
+    int active;
+    int strict_set;
+    int strict_enabled;
+    int tls_min_set;
+    int tls_min;
+    int tls_max_set;
+    int tls_max;
+    uint16_t *cipher_suites;
+    size_t cipher_suites_len;
+    OSSL_JA4_MODE cipher_mode;
+    unsigned char *alpn_wire;
+    size_t alpn_wire_len;
+    uint16_t *signature_algorithms;
+    size_t signature_algorithms_len;
+    uint16_t *supported_versions;
+    size_t supported_versions_len;
+    uint16_t *supported_groups;
+    size_t supported_groups_len;
+    uint16_t *key_share_groups;
+    size_t key_share_groups_len;
+    unsigned char *psk_key_exchange_modes;
+    size_t psk_key_exchange_modes_len;
+    uint16_t *extension_order;
+    size_t extension_order_len;
+    OSSL_JA4_MODE extension_mode;
+    OSSL_JA4_SNI_MODE sni_mode;
+    int grease_set;
+    int grease_enabled;
+    int grease_value_set;
+    uint16_t grease_value;
+    int enable_ch_xtn_permutation;
+    int enable_ch_xtn_permutation_set;
+} OSSL_JA4_CONFIG;
+
+typedef struct {
+    OSSL_JA4_CONFIG config;
+    uint16_t *final_cipher_suites;
+    size_t final_cipher_suites_len;
+    uint16_t *final_signature_algorithms;
+    size_t final_signature_algorithms_len;
+    uint16_t *final_extensions;
+    size_t final_extensions_len;
+    uint16_t *final_supported_versions;
+    size_t final_supported_versions_len;
+    uint16_t *final_supported_groups;
+    size_t final_supported_groups_len;
+    uint16_t *final_key_share_groups;
+    size_t final_key_share_groups_len;
+    unsigned char *final_psk_key_exchange_modes;
+    size_t final_psk_key_exchange_modes_len;
+    uint32_t mismatch_mask;
+    int apply_ok;
+} OSSL_JA4_STATE;
+
+static OSSL_JA4_STATE ossl_ja4_state = {{0}, NULL, 0, NULL, 0, NULL, 0};
+
+static const uint16_t ossl_ja4_grease_values[] = {
+    0x0a0a, 0x1a1a, 0x2a2a, 0x3a3a,
+    0x4a4a, 0x5a5a, 0x6a6a, 0x7a7a,
+    0x8a8a, 0x9a9a, 0xaaaa, 0xbaba,
+    0xcaca, 0xdada, 0xeaea, 0xfafa
+};
+
+static void ossl_ja4_reset_dynamic(uint16_t **vals, size_t *vals_len)
+{
+    OPENSSL_free(*vals);
+    *vals = NULL;
+    *vals_len = 0;
+}
+
+static void ossl_ja4_reset_config(OSSL_JA4_CONFIG *cfg)
+{
+    OPENSSL_free(cfg->cipher_suites);
+    OPENSSL_free(cfg->alpn_wire);
+    OPENSSL_free(cfg->signature_algorithms);
+    OPENSSL_free(cfg->supported_versions);
+    OPENSSL_free(cfg->supported_groups);
+    OPENSSL_free(cfg->key_share_groups);
+    OPENSSL_free(cfg->psk_key_exchange_modes);
+    OPENSSL_free(cfg->extension_order);
+    memset(cfg, 0, sizeof(*cfg));
+}
+
+static void ossl_ja4_reset_state(void)
+{
+    ossl_ja4_reset_config(&ossl_ja4_state.config);
+    ossl_ja4_reset_dynamic(&ossl_ja4_state.final_cipher_suites,
+        &ossl_ja4_state.final_cipher_suites_len);
+    ossl_ja4_reset_dynamic(&ossl_ja4_state.final_signature_algorithms,
+        &ossl_ja4_state.final_signature_algorithms_len);
+    ossl_ja4_reset_dynamic(&ossl_ja4_state.final_extensions,
+        &ossl_ja4_state.final_extensions_len);
+    ossl_ja4_reset_dynamic(&ossl_ja4_state.final_supported_versions,
+        &ossl_ja4_state.final_supported_versions_len);
+    ossl_ja4_reset_dynamic(&ossl_ja4_state.final_supported_groups,
+        &ossl_ja4_state.final_supported_groups_len);
+    ossl_ja4_reset_dynamic(&ossl_ja4_state.final_key_share_groups,
+        &ossl_ja4_state.final_key_share_groups_len);
+    OPENSSL_free(ossl_ja4_state.final_psk_key_exchange_modes);
+    ossl_ja4_state.final_psk_key_exchange_modes = NULL;
+    ossl_ja4_state.final_psk_key_exchange_modes_len = 0;
+    ossl_ja4_state.mismatch_mask = 0;
+    ossl_ja4_state.apply_ok = 0;
+}
+
+static char *ossl_ja4_trim(char *value)
+{
+    char *end;
+
+    while (*value != '\0' && (*value == ' ' || *value == '\t'
+            || *value == '\r' || *value == '\n')) {
+        value++;
+    }
+
+    end = value + strlen(value);
+    while (end > value) {
+        char c = end[-1];
+
+        if (c != ' ' && c != '\t' && c != '\r' && c != '\n')
+            break;
+        end--;
+    }
+    *end = '\0';
+    return value;
+}
+
+static int ossl_ja4_parse_tls_version(const char *value, int *out)
+{
+    if (strcmp(value, "1.0") == 0) {
+        *out = TLS1_VERSION;
+        return 1;
+    }
+    if (strcmp(value, "1.1") == 0) {
+        *out = TLS1_1_VERSION;
+        return 1;
+    }
+    if (strcmp(value, "1.2") == 0) {
+        *out = TLS1_2_VERSION;
+        return 1;
+    }
+    if (strcmp(value, "1.3") == 0) {
+        *out = TLS1_3_VERSION;
+        return 1;
+    }
+
+    {
+        char *end = NULL;
+        unsigned long parsed = strtoul(value, &end, 0);
+
+        if (end != NULL && *end == '\0' && parsed <= 0xffffUL) {
+            *out = (int)parsed;
+            return 1;
+        }
+    }
+
+    return 0;
+}
+
+static int ossl_ja4_parse_mode(const char *value, OSSL_JA4_MODE *out)
+{
+    if (OPENSSL_strcasecmp(value, "reorder") == 0) {
+        *out = OSSL_JA4_MODE_REORDER_VAL;
+        return 1;
+    }
+    if (OPENSSL_strcasecmp(value, "exact") == 0) {
+        *out = OSSL_JA4_MODE_EXACT_VAL;
+        return 1;
+    }
+    return 0;
+}
+
+static int ossl_ja4_parse_sni_mode(const char *value, OSSL_JA4_SNI_MODE *out)
+{
+    if (OPENSSL_strcasecmp(value, "present") == 0) {
+        *out = OSSL_JA4_SNI_PRESENT;
+        return 1;
+    }
+    if (OPENSSL_strcasecmp(value, "domain") == 0) {
+        *out = OSSL_JA4_SNI_DOMAIN;
+        return 1;
+    }
+    if (OPENSSL_strcasecmp(value, "none") == 0) {
+        *out = OSSL_JA4_SNI_NONE;
+        return 1;
+    }
+    if (OPENSSL_strcasecmp(value, "ip") == 0) {
+        *out = OSSL_JA4_SNI_IP;
+        return 1;
+    }
+    return 0;
+}
+
+static int ossl_ja4_parse_bool(const char *value, int *out)
+{
+    if (OPENSSL_strcasecmp(value, "1") == 0
+        || OPENSSL_strcasecmp(value, "true") == 0
+        || OPENSSL_strcasecmp(value, "yes") == 0
+        || OPENSSL_strcasecmp(value, "on") == 0) {
+        *out = 1;
+        return 1;
+    }
+    if (OPENSSL_strcasecmp(value, "0") == 0
+        || OPENSSL_strcasecmp(value, "false") == 0
+        || OPENSSL_strcasecmp(value, "no") == 0
+        || OPENSSL_strcasecmp(value, "off") == 0) {
+        *out = 0;
+        return 1;
+    }
+    return 0;
+}
+
+static int ossl_ja4_parse_csv_u16(const char *value, uint16_t **out,
+    size_t *out_len)
+{
+    char *tmp = NULL;
+    char *cursor = NULL;
+    size_t count = 0;
+    uint16_t *parsed = NULL;
+
+    tmp = OPENSSL_strdup(value);
+    if (tmp == NULL)
+        return 0;
+
+    for (cursor = strtok(tmp, ","); cursor != NULL; cursor = strtok(NULL, ",")) {
+        count++;
+    }
+    OPENSSL_free(tmp);
+
+    if (count == 0) {
+        *out = NULL;
+        *out_len = 0;
+        return 1;
+    }
+
+    parsed = OPENSSL_malloc_array(count, sizeof(*parsed));
+    tmp = OPENSSL_strdup(value);
+    if (parsed == NULL || tmp == NULL)
+        goto err;
+
+    count = 0;
+    for (cursor = strtok(tmp, ","); cursor != NULL; cursor = strtok(NULL, ",")) {
+        char *end = NULL;
+        unsigned long item;
+        char *trimmed = ossl_ja4_trim(cursor);
+
+        item = strtoul(trimmed, &end, 0);
+        if (end == NULL || *end != '\0' || item > 0xffffUL)
+            goto err;
+        parsed[count++] = (uint16_t)item;
+    }
+
+    OPENSSL_free(tmp);
+    *out = parsed;
+    *out_len = count;
+    return 1;
+err:
+    OPENSSL_free(parsed);
+    OPENSSL_free(tmp);
+    return 0;
+}
+
+static int ossl_ja4_parse_csv_u8(const char *value, unsigned char **out,
+    size_t *out_len)
+{
+    char *tmp = NULL;
+    char *cursor = NULL;
+    size_t count = 0;
+    unsigned char *parsed = NULL;
+
+    tmp = OPENSSL_strdup(value);
+    if (tmp == NULL)
+        return 0;
+
+    for (cursor = strtok(tmp, ","); cursor != NULL; cursor = strtok(NULL, ",")) {
+        count++;
+    }
+    OPENSSL_free(tmp);
+
+    if (count == 0) {
+        *out = NULL;
+        *out_len = 0;
+        return 1;
+    }
+
+    parsed = OPENSSL_malloc_array(count, sizeof(*parsed));
+    tmp = OPENSSL_strdup(value);
+    if (parsed == NULL || tmp == NULL)
+        goto err;
+
+    count = 0;
+    for (cursor = strtok(tmp, ","); cursor != NULL; cursor = strtok(NULL, ",")) {
+        char *end = NULL;
+        unsigned long item;
+        char *trimmed = ossl_ja4_trim(cursor);
+
+        item = strtoul(trimmed, &end, 0);
+        if (end == NULL || *end != '\0' || item > 0xffUL)
+            goto err;
+        parsed[count++] = (unsigned char)item;
+    }
+
+    OPENSSL_free(tmp);
+    *out = parsed;
+    *out_len = count;
+    return 1;
+err:
+    OPENSSL_free(parsed);
+    OPENSSL_free(tmp);
+    return 0;
+}
+
+static int ossl_ja4_parse_alpn_wire(const char *value, unsigned char **out,
+    size_t *out_len)
+{
+    char *tmp = NULL;
+    char *cursor = NULL;
+    size_t total = 0;
+    unsigned char *wire = NULL;
+    unsigned char *p = NULL;
+
+    tmp = OPENSSL_strdup(value);
+    if (tmp == NULL)
+        return 0;
+
+    for (cursor = strtok(tmp, ","); cursor != NULL; cursor = strtok(NULL, ",")) {
+        size_t token_len = strlen(ossl_ja4_trim(cursor));
+
+        if (token_len == 0 || token_len > 255)
+            goto err;
+        total += token_len + 1;
+    }
+
+    wire = OPENSSL_malloc(total == 0 ? 1 : total);
+    OPENSSL_free(tmp);
+    tmp = OPENSSL_strdup(value);
+    if (wire == NULL || tmp == NULL)
+        goto err;
+
+    p = wire;
+    for (cursor = strtok(tmp, ","); cursor != NULL; cursor = strtok(NULL, ",")) {
+        size_t token_len;
+        char *trimmed = ossl_ja4_trim(cursor);
+
+        token_len = strlen(trimmed);
+        *p++ = (unsigned char)token_len;
+        memcpy(p, trimmed, token_len);
+        p += token_len;
+    }
+
+    OPENSSL_free(tmp);
+    *out = wire;
+    *out_len = total;
+    return 1;
+err:
+    OPENSSL_free(wire);
+    OPENSSL_free(tmp);
+    return 0;
+}
+
+static int ossl_ja4_append_u16(uint16_t **vals, size_t *vals_len, uint16_t value)
+{
+    uint16_t *next = OPENSSL_realloc(*vals, (*vals_len + 1) * sizeof(*next));
+
+    if (next == NULL)
+        return 0;
+    next[*vals_len] = value;
+    *vals = next;
+    (*vals_len)++;
+    return 1;
+}
+
+static int ossl_ja4_contains_u16(const uint16_t *vals, size_t vals_len,
+    uint16_t value)
+{
+    size_t i;
+
+    for (i = 0; i < vals_len; i++) {
+        if (vals[i] == value)
+            return 1;
+    }
+    return 0;
+}
+
+static int ossl_ja4_insert_u16_at(uint16_t **vals, size_t *vals_len,
+    size_t index, uint16_t value)
+{
+    uint16_t *next;
+
+    if (index > *vals_len)
+        index = *vals_len;
+
+    next = OPENSSL_realloc(*vals, (*vals_len + 1) * sizeof(*next));
+    if (next == NULL)
+        return 0;
+
+    if (index < *vals_len) {
+        memmove(&next[index + 1], &next[index],
+            (*vals_len - index) * sizeof(*next));
+    }
+
+    next[index] = value;
+    *vals = next;
+    (*vals_len)++;
+    return 1;
+}
+
+static int ossl_ja4_normalize_extension_order(void)
+{
+    OSSL_JA4_CONFIG *cfg = &ossl_ja4_state.config;
+    size_t i;
+    size_t insert_pos;
+
+    if (cfg->extension_mode != OSSL_JA4_MODE_EXACT_VAL
+        || cfg->extension_order_len == 0) {
+        return 1;
+    }
+
+    /*
+     * JA4 extension lists often omit SNI (0) and ALPN (16). In strict exact
+     * mode that omission can make browser-style replays fail. Normalize the
+     * configured order so these protocol-critical extensions are present when
+     * their corresponding features are enabled.
+     */
+    if (cfg->sni_mode != OSSL_JA4_SNI_NONE
+        && cfg->sni_mode != OSSL_JA4_SNI_IP
+        && !ossl_ja4_contains_u16(cfg->extension_order,
+            cfg->extension_order_len, TLSEXT_TYPE_server_name)) {
+        if (!ossl_ja4_insert_u16_at(&cfg->extension_order,
+                &cfg->extension_order_len, 0, TLSEXT_TYPE_server_name)) {
+            return 0;
+        }
+    }
+
+    if (cfg->alpn_wire != NULL && cfg->alpn_wire_len > 0
+        && !ossl_ja4_contains_u16(cfg->extension_order,
+            cfg->extension_order_len, TLSEXT_TYPE_application_layer_protocol_negotiation)) {
+        insert_pos = cfg->extension_order_len;
+        for (i = 0; i < cfg->extension_order_len; i++) {
+            if (cfg->extension_order[i] == TLSEXT_TYPE_signature_algorithms) {
+                insert_pos = i + 1;
+                break;
+            }
+        }
+        if (!ossl_ja4_insert_u16_at(&cfg->extension_order,
+                &cfg->extension_order_len, insert_pos,
+                TLSEXT_TYPE_application_layer_protocol_negotiation)) {
+            return 0;
+        }
+    }
+
+    /*
+     * Phase 2 dependency closure: when a value-bearing config knob is set
+     * (sigalgs, supported_groups, key_share_groups, supported_versions,
+     * psk_key_exchange_modes) but the user-supplied extension_order omits
+     * the matching extension type, silently auto-inject it at the tail. The
+     * apply path emits the new entry, so finalize_mismatches sees it in
+     * final_extension_order and the 0x0400 drift bit stays clear.
+     */
+    if (cfg->signature_algorithms_len > 0
+        && !ossl_ja4_contains_u16(cfg->extension_order,
+            cfg->extension_order_len, TLSEXT_TYPE_signature_algorithms)) {
+        if (!ossl_ja4_insert_u16_at(&cfg->extension_order,
+                &cfg->extension_order_len, cfg->extension_order_len,
+                TLSEXT_TYPE_signature_algorithms)) {
+            return 0;
+        }
+    }
+
+    if (cfg->supported_groups_len > 0
+        && !ossl_ja4_contains_u16(cfg->extension_order,
+            cfg->extension_order_len, TLSEXT_TYPE_supported_groups)) {
+        if (!ossl_ja4_insert_u16_at(&cfg->extension_order,
+                &cfg->extension_order_len, cfg->extension_order_len,
+                TLSEXT_TYPE_supported_groups)) {
+            return 0;
+        }
+    }
+
+    if (cfg->key_share_groups_len > 0
+        && !ossl_ja4_contains_u16(cfg->extension_order,
+            cfg->extension_order_len, TLSEXT_TYPE_key_share)) {
+        if (!ossl_ja4_insert_u16_at(&cfg->extension_order,
+                &cfg->extension_order_len, cfg->extension_order_len,
+                TLSEXT_TYPE_key_share)) {
+            return 0;
+        }
+    }
+
+    if (cfg->supported_versions_len > 0
+        && !ossl_ja4_contains_u16(cfg->extension_order,
+            cfg->extension_order_len, TLSEXT_TYPE_supported_versions)) {
+        if (!ossl_ja4_insert_u16_at(&cfg->extension_order,
+                &cfg->extension_order_len, cfg->extension_order_len,
+                TLSEXT_TYPE_supported_versions)) {
+            return 0;
+        }
+    }
+
+    if (cfg->psk_key_exchange_modes_len > 0
+        && !ossl_ja4_contains_u16(cfg->extension_order,
+            cfg->extension_order_len, TLSEXT_TYPE_psk_kex_modes)) {
+        if (!ossl_ja4_insert_u16_at(&cfg->extension_order,
+                &cfg->extension_order_len, cfg->extension_order_len,
+                TLSEXT_TYPE_psk_kex_modes)) {
+            return 0;
+        }
+    }
+
+    return 1;
+}
+
+static void ossl_ja4_parse_file(const char *path)
+{
+    FILE *fp = NULL;
+    char line[4096];
+
+    fp = fopen(path, "r");
+    if (fp == NULL)
+        return;
+
+    while (fgets(line, sizeof(line), fp) != NULL) {
+        char *eq;
+        char *key;
+        char *value;
+
+        key = ossl_ja4_trim(line);
+        if (*key == '\0' || *key == '#')
+            continue;
+
+        eq = strchr(key, '=');
+        if (eq == NULL)
+            continue;
+        *eq = '\0';
+        value = ossl_ja4_trim(eq + 1);
+        key = ossl_ja4_trim(key);
+
+        if (strcmp(key, "strict") == 0) {
+            int parsed;
+
+            if (ossl_ja4_parse_bool(value, &parsed)) {
+                ossl_ja4_state.config.strict_set = 1;
+                ossl_ja4_state.config.strict_enabled = parsed;
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "tls_min") == 0) {
+            int parsed;
+
+            if (ossl_ja4_parse_tls_version(value, &parsed)) {
+                ossl_ja4_state.config.tls_min = parsed;
+                ossl_ja4_state.config.tls_min_set = 1;
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "tls_max") == 0) {
+            int parsed;
+
+            if (ossl_ja4_parse_tls_version(value, &parsed)) {
+                ossl_ja4_state.config.tls_max = parsed;
+                ossl_ja4_state.config.tls_max_set = 1;
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "cipher_suites") == 0) {
+            OPENSSL_free(ossl_ja4_state.config.cipher_suites);
+            if (ossl_ja4_parse_csv_u16(value,
+                    &ossl_ja4_state.config.cipher_suites,
+                    &ossl_ja4_state.config.cipher_suites_len)) {
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "cipher_mode") == 0) {
+            if (ossl_ja4_parse_mode(value, &ossl_ja4_state.config.cipher_mode))
+                ossl_ja4_state.config.active = 1;
+        } else if (strcmp(key, "alpn") == 0) {
+            OPENSSL_free(ossl_ja4_state.config.alpn_wire);
+            if (ossl_ja4_parse_alpn_wire(value,
+                    &ossl_ja4_state.config.alpn_wire,
+                    &ossl_ja4_state.config.alpn_wire_len)) {
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "signature_algorithms") == 0) {
+            OPENSSL_free(ossl_ja4_state.config.signature_algorithms);
+            if (ossl_ja4_parse_csv_u16(value,
+                    &ossl_ja4_state.config.signature_algorithms,
+                    &ossl_ja4_state.config.signature_algorithms_len)) {
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "supported_versions") == 0) {
+            OPENSSL_free(ossl_ja4_state.config.supported_versions);
+            if (ossl_ja4_parse_csv_u16(value,
+                    &ossl_ja4_state.config.supported_versions,
+                    &ossl_ja4_state.config.supported_versions_len)) {
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "supported_groups") == 0) {
+            OPENSSL_free(ossl_ja4_state.config.supported_groups);
+            if (ossl_ja4_parse_csv_u16(value,
+                    &ossl_ja4_state.config.supported_groups,
+                    &ossl_ja4_state.config.supported_groups_len)) {
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "key_share_groups") == 0) {
+            OPENSSL_free(ossl_ja4_state.config.key_share_groups);
+            if (ossl_ja4_parse_csv_u16(value,
+                    &ossl_ja4_state.config.key_share_groups,
+                    &ossl_ja4_state.config.key_share_groups_len)) {
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "psk_key_exchange_modes") == 0) {
+            OPENSSL_free(ossl_ja4_state.config.psk_key_exchange_modes);
+            if (ossl_ja4_parse_csv_u8(value,
+                    &ossl_ja4_state.config.psk_key_exchange_modes,
+                    &ossl_ja4_state.config.psk_key_exchange_modes_len)) {
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "extension_order") == 0) {
+            OPENSSL_free(ossl_ja4_state.config.extension_order);
+            if (ossl_ja4_parse_csv_u16(value,
+                    &ossl_ja4_state.config.extension_order,
+                    &ossl_ja4_state.config.extension_order_len)) {
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "extension_mode") == 0) {
+            if (ossl_ja4_parse_mode(value, &ossl_ja4_state.config.extension_mode))
+                ossl_ja4_state.config.active = 1;
+        } else if (strcmp(key, "sni_mode") == 0) {
+            if (ossl_ja4_parse_sni_mode(value, &ossl_ja4_state.config.sni_mode))
+                ossl_ja4_state.config.active = 1;
+        } else if (strcmp(key, "enable_grease") == 0) {
+            int parsed;
+
+            if (ossl_ja4_parse_bool(value, &parsed)) {
+                ossl_ja4_state.config.grease_set = 1;
+                ossl_ja4_state.config.grease_enabled = parsed;
+                ossl_ja4_state.config.active = 1;
+            }
+        } else if (strcmp(key, "grease_value") == 0) {
+            unsigned long parsed_ul;
+            char *endptr = NULL;
+
+            errno = 0;
+            parsed_ul = strtoul(value, &endptr, 0);
+            if (errno == 0 && endptr != value && *endptr == '\0'
+                && parsed_ul <= 0xFFFFu) {
+                ossl_ja4_state.config.grease_value = (uint16_t)parsed_ul;
+                ossl_ja4_state.config.grease_value_set = 1;
+                ossl_ja4_state.config.active = 1;
+            } else {
+                ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_INVALID_CONFIG;
+            }
+        } else if (strcmp(key, "enable_ch_xtn_permutation") == 0) {
+            int parsed;
+
+            if (ossl_ja4_parse_bool(value, &parsed)) {
+                ossl_ja4_state.config.enable_ch_xtn_permutation = parsed;
+                ossl_ja4_state.config.enable_ch_xtn_permutation_set = 1;
+                ossl_ja4_state.config.active = 1;
+                /*
+                 * Real permutation now happens in
+                 * ossl_ja4_rewrite_client_hello_wire via
+                 * ossl_ja4_permute_extensions_inplace; no parser-side
+                 * mismatch raise. If the in-place reorder fails at runtime
+                 * (parse error or OOM) the wire-rewrite path raises
+                 * OSSL_JA4_MISMATCH_INVALID_CONFIG and strict mode aborts.
+                 */
+            }
+        } else {
+            ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_UNKNOWN_KEY;
+        }
+    }
+
+    fclose(fp);
+}
+
+static uint16_t ossl_ja4_pick_grease_value(void)
+{
+    unsigned char r = 0;
+
+    if (RAND_bytes(&r, sizeof(r)) <= 0)
+        return ossl_ja4_grease_values[0];
+    return ossl_ja4_grease_values[r & 0x0f];
+}
+
+int ossl_ja4_prepare_client_hello(SSL_CONNECTION *s)
+{
+    const char *config_path = ossl_safe_getenv("OPENSSL_JA4_CONFIG");
+    uint16_t *groups_dup = NULL;
+    size_t *tuples_dup = NULL;
+    uint16_t *keyshares_dup = NULL;
+
+    ossl_ja4_reset_state();
+    if (config_path == NULL || *config_path == '\0')
+        return 1;
+
+    ossl_ja4_parse_file(config_path);
+    if (!ossl_ja4_state.config.active)
+        return 1;
+    if (!ossl_ja4_normalize_extension_order())
+        return 0;
+
+    if (ossl_ja4_state.config.grease_set
+        && ossl_ja4_state.config.grease_enabled
+        && !ossl_ja4_state.config.grease_value_set) {
+        ossl_ja4_state.config.grease_value = ossl_ja4_pick_grease_value();
+        ossl_ja4_state.config.grease_value_set = 1;
+    }
+
+    if (ossl_ja4_state.config.tls_min_set)
+        s->min_proto_version = ossl_ja4_state.config.tls_min;
+    if (ossl_ja4_state.config.tls_max_set)
+        s->max_proto_version = ossl_ja4_state.config.tls_max;
+    if (ossl_ja4_state.config.alpn_wire != NULL) {
+        unsigned char *dup = OPENSSL_memdup(ossl_ja4_state.config.alpn_wire,
+            ossl_ja4_state.config.alpn_wire_len);
+
+        if (dup == NULL)
+            return 0;
+        OPENSSL_free(s->ext.alpn);
+        s->ext.alpn = dup;
+        s->ext.alpn_len = ossl_ja4_state.config.alpn_wire_len;
+    }
+    if (ossl_ja4_state.config.signature_algorithms_len > 0
+        && !tls1_set_raw_sigalgs(s->cert,
+            ossl_ja4_state.config.signature_algorithms,
+            ossl_ja4_state.config.signature_algorithms_len, 0)) {
+        goto err;
+    }
+    if (ossl_ja4_state.config.supported_groups_len > 0) {
+        groups_dup = OPENSSL_memdup(ossl_ja4_state.config.supported_groups,
+            ossl_ja4_state.config.supported_groups_len * sizeof(*groups_dup));
+        tuples_dup = OPENSSL_malloc(sizeof(*tuples_dup));
+        if (groups_dup == NULL || tuples_dup == NULL)
+            goto err;
+        tuples_dup[0] = ossl_ja4_state.config.supported_groups_len;
+        OPENSSL_free(s->ext.supportedgroups);
+        OPENSSL_free(s->ext.tuples);
+        s->ext.supportedgroups = groups_dup;
+        s->ext.supportedgroups_len = ossl_ja4_state.config.supported_groups_len;
+        s->ext.tuples = tuples_dup;
+        s->ext.tuples_len = 1;
+        groups_dup = NULL;
+        tuples_dup = NULL;
+    }
+    if (ossl_ja4_state.config.key_share_groups_len > 0) {
+        keyshares_dup = OPENSSL_memdup(ossl_ja4_state.config.key_share_groups,
+            ossl_ja4_state.config.key_share_groups_len * sizeof(*keyshares_dup));
+        if (keyshares_dup == NULL)
+            goto err;
+        OPENSSL_free(s->ext.keyshares);
+        s->ext.keyshares = keyshares_dup;
+        s->ext.keyshares_len = ossl_ja4_state.config.key_share_groups_len;
+        keyshares_dup = NULL;
+    }
+
+    return 1;
+err:
+    OPENSSL_free(groups_dup);
+    OPENSSL_free(tuples_dup);
+    OPENSSL_free(keyshares_dup);
+    return 0;
+}
