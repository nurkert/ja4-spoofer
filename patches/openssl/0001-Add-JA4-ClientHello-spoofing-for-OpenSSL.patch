+static void ossl_ja4_write_csv_u16(FILE *fp, const char *key,
+    const uint16_t *vals, size_t vals_len)
+{
+    size_t i;
+
+    fprintf(fp, "%s=", key);
+    for (i = 0; i < vals_len; i++) {
+        if (i > 0)
+            fputc(',', fp);
+        fprintf(fp, "%u", vals[i]);
+    }
+    fputc('\n', fp);
+}
+
+static void ossl_ja4_write_csv_u8(FILE *fp, const char *key,
+    const unsigned char *vals, size_t vals_len)
+{
+    size_t i;
+
+    fprintf(fp, "%s=", key);
+    for (i = 0; i < vals_len; i++) {
+        if (i > 0)
+            fputc(',', fp);
+        fprintf(fp, "%u", vals[i]);
+    }
+    fputc('\n', fp);
+}
+
+static void ossl_ja4_write_csv_alpn(FILE *fp, const char *key,
+    const unsigned char *wire, size_t wire_len)
+{
+    size_t pos = 0;
+    int first = 1;
+
+    fprintf(fp, "%s=", key);
+    while (pos < wire_len) {
+        size_t token_len = wire[pos++];
+
+        if (pos + token_len > wire_len)
+            break;
+        if (!first)
+            fputc(',', fp);
+        fwrite(wire + pos, 1, token_len, fp);
+        pos += token_len;
+        first = 0;
+    }
+    fputc('\n', fp);
+}
+
+static int ossl_ja4_lists_equal_u16(const uint16_t *req, size_t req_len,
+    const uint16_t *fin, size_t fin_len)
+{
+    size_t i;
+
+    if (req_len != fin_len)
+        return 0;
+    for (i = 0; i < req_len; i++) {
+        if (req[i] != fin[i])
+            return 0;
+    }
+    return 1;
+}
+
+/*
+ * Equality with tolerance for a single trailing GREASE entry on the final
+ * side. With enable_grease=1, OpenSSL appends one GREASE value (e.g. to
+ * signature_algorithms) which is intentional — not a mismatch.
+ */
+static int ossl_ja4_lists_equal_u16_with_trailing_grease(const uint16_t *req,
+    size_t req_len, const uint16_t *fin, size_t fin_len)
+{
+    uint16_t grease;
+
+    if (ossl_ja4_lists_equal_u16(req, req_len, fin, fin_len))
+        return 1;
+    if (!ossl_ja4_state.config.grease_enabled
+        || !ossl_ja4_get_grease_value(&grease))
+        return 0;
+    if (fin_len != req_len + 1)
+        return 0;
+    if (fin[fin_len - 1] != grease)
+        return 0;
+    return ossl_ja4_lists_equal_u16(req, req_len, fin, req_len);
+}
+
+static int ossl_ja4_lists_equal_u8(const unsigned char *req, size_t req_len,
+    const unsigned char *fin, size_t fin_len)
+{
+    size_t i;
+
+    if (req_len != fin_len)
+        return 0;
+    for (i = 0; i < req_len; i++) {
+        if (req[i] != fin[i])
+            return 0;
+    }
+    return 1;
+}
+
+/*
+ * Strip a trailing PSK-pre_shared_key (41) entry before comparing the
+ * extension order. JA4-style canonicalization treats the PSK extension as
+ * "always-last" and excludes it from the requested order.
+ */
+static size_t ossl_ja4_extension_compare_len(const uint16_t *vals, size_t len)
+{
+    if (len > 0 && vals[len - 1] == TLSEXT_TYPE_psk)
+        return len - 1;
+    return len;
+}
+
+static int ossl_ja4_alpn_wire_equal(const unsigned char *req, size_t req_len,
+    const unsigned char *fin, size_t fin_len)
+{
+    if (req_len != fin_len)
+        return 0;
+    if (req_len == 0)
+        return 1;
+    return memcmp(req, fin, req_len) == 0;
+}
+
+/*
+ * Wire-emission validation: in extension_mode=exact, every requested
+ * extension type must actually appear in the post-construct extension list
+ * collected from the WPACKET. Anything missing raises 0x0040
+ * (missing_requested_extension). This runs before finalize_mismatches'
+ * apply_ok latch so a missed extension correctly clears apply_ok.
+ */
+static void ossl_ja4_validate_emitted_extensions(void)
+{
+    OSSL_JA4_CONFIG *cfg = &ossl_ja4_state.config;
+    size_t i;
+
+    if (!cfg->active)
+        return;
+    if (cfg->extension_mode != OSSL_JA4_MODE_EXACT_VAL)
+        return;
+    if (cfg->extension_order_len == 0)
+        return;
+
+    for (i = 0; i < cfg->extension_order_len; i++) {
+        if (!ossl_ja4_contains_u16(ossl_ja4_state.final_extensions,
+                ossl_ja4_state.final_extensions_len,
+                cfg->extension_order[i])) {
+            ossl_ja4_state.mismatch_mask
+                |= OSSL_JA4_MISMATCH_MISSING_EXTENSION;
+            break;
+        }
+    }
+}
+
+static void ossl_ja4_finalize_mismatches(void)
+{
+    OSSL_JA4_CONFIG *cfg = &ossl_ja4_state.config;
+
+    ossl_ja4_validate_emitted_extensions();
+
+    /* ossl_ja4_note_cipher_suites drift -> 0x0080 */
+    if (cfg->cipher_suites_len > 0
+        && !ossl_ja4_lists_equal_u16(cfg->cipher_suites, cfg->cipher_suites_len,
+            ossl_ja4_state.final_cipher_suites,
+            ossl_ja4_state.final_cipher_suites_len)) {
+        ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_CIPHER_SUITES;
+    }
+
+    /* ossl_ja4_note_alpn drift -> 0x0100 */
+    if (cfg->alpn_wire != NULL && cfg->alpn_wire_len > 0
+        && !ossl_ja4_alpn_wire_equal(cfg->alpn_wire, cfg->alpn_wire_len,
+            cfg->alpn_wire, cfg->alpn_wire_len)) {
+        ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_ALPN;
+    }
+
+    /* ossl_ja4_note_signature_algorithms drift -> 0x0200 (GREASE-tolerant) */
+    if (cfg->signature_algorithms_len > 0
+        && !ossl_ja4_lists_equal_u16_with_trailing_grease(
+            cfg->signature_algorithms,
+            cfg->signature_algorithms_len,
+            ossl_ja4_state.final_signature_algorithms,
+            ossl_ja4_state.final_signature_algorithms_len)) {
+        ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_SIGNATURE_ALGORITHMS;
+    }
+
+    /* ossl_ja4_note_extension_order drift -> 0x0400 (modulo PSK-last) */
+    if (cfg->extension_order_len > 0) {
+        size_t req_cmp_len = ossl_ja4_extension_compare_len(cfg->extension_order,
+            cfg->extension_order_len);
+        size_t fin_cmp_len = ossl_ja4_extension_compare_len(
+            ossl_ja4_state.final_extensions,
+            ossl_ja4_state.final_extensions_len);
+
+        if (!ossl_ja4_lists_equal_u16(cfg->extension_order, req_cmp_len,
+                ossl_ja4_state.final_extensions, fin_cmp_len)) {
+            ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_EXTENSION_ORDER;
+        }
+    }
+
+    /* ossl_ja4_note_supported_versions drift -> 0x0008 */
+    if (cfg->supported_versions_len > 0
+        && !ossl_ja4_lists_equal_u16(cfg->supported_versions,
+            cfg->supported_versions_len,
+            ossl_ja4_state.final_supported_versions,
+            ossl_ja4_state.final_supported_versions_len)) {
+        ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_SUPPORTED_VERSIONS;
+    }
+
+    /* ossl_ja4_note_supported_groups drift -> 0x0800 */
+    if (cfg->supported_groups_len > 0
+        && !ossl_ja4_lists_equal_u16(cfg->supported_groups,
+            cfg->supported_groups_len,
+            ossl_ja4_state.final_supported_groups,
+            ossl_ja4_state.final_supported_groups_len)) {
+        ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_SUPPORTED_GROUPS;
+    }
+
+    /* ossl_ja4_note_key_share drift -> 0x0004 */
+    if (cfg->key_share_groups_len > 0
+        && !ossl_ja4_lists_equal_u16(cfg->key_share_groups,
+            cfg->key_share_groups_len,
+            ossl_ja4_state.final_key_share_groups,
+            ossl_ja4_state.final_key_share_groups_len)) {
+        ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_KEY_SHARES;
+    }
+
+    /* ossl_ja4_note_psk_key_exchange_modes drift -> 0x1000 */
+    if (cfg->psk_key_exchange_modes_len > 0
+        && !ossl_ja4_lists_equal_u8(cfg->psk_key_exchange_modes,
+            cfg->psk_key_exchange_modes_len,
+            ossl_ja4_state.final_psk_key_exchange_modes,
+            ossl_ja4_state.final_psk_key_exchange_modes_len)) {
+        ossl_ja4_state.mismatch_mask |= OSSL_JA4_MISMATCH_PSK_KEX_MODES;
+    }
+
+    ossl_ja4_state.apply_ok = (ossl_ja4_state.mismatch_mask == 0) ? 1 : 0;
+}
+
+int ossl_ja4_get_mismatch_mask(uint32_t *out)
+{
+    if (out == NULL)
+        return 0;
+    *out = ossl_ja4_state.mismatch_mask;
+    return 1;
+}
+
+static const char *ossl_ja4_sni_mode_str(OSSL_JA4_SNI_MODE mode)
+{
+    switch (mode) {
+    case OSSL_JA4_SNI_PRESENT:
+        return "present";
+    case OSSL_JA4_SNI_DOMAIN:
+        return "domain";
+    case OSSL_JA4_SNI_NONE:
+        return "none";
+    case OSSL_JA4_SNI_IP:
+        return "ip";
+    case OSSL_JA4_SNI_UNSET:
+    default:
+        return "present";
+    }
+}
