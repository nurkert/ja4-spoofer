 #include "ssl3exthandle.h"
+#include "tls13con.h"
 #include "tls13ech.h"
 #include "tls13exthandle.h"
 #include "tls13psk.h"
@@ -37,8 +38,11 @@
 #include "secmod.h"
 #include "blapi.h"
 
+#include <ctype.h>
 #include <limits.h>
 #include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
 
 static PK11SymKey *ssl3_GenerateRSAPMS(sslSocket *ss, ssl3CipherSpec *spec,
                                        PK11SlotInfo *serverKeySlot);
@@ -85,6 +89,2187 @@ const PRUint8 ssl_hello_retry_random[] = {
 };
 PR_STATIC_ASSERT(PR_ARRAY_SIZE(ssl_hello_retry_random) == SSL3_RANDOM_LENGTH);
 
+/* Minimal JA4 config/dump hook:
+ *   NSS_JA4_CONFIG=/path/file.conf
+ *   NSS_JA4_DUMP=/path/file.conf
+ */
+#define SSL3_JA4_CFG_MAX_LIST 256
+#define SSL3_JA4_CFG_MAX_ALPN 4096
+#define SSL3_JA4_CFG_MAX_UNKNOWN_KEY 64
+
+typedef enum {
+    ssl3Ja4CipherModeReorder = 0,
+    ssl3Ja4CipherModeExact = 1
+} ssl3Ja4CipherMode;
+
+typedef enum {
+    ssl3Ja4ExtensionModeReorder = 0,
+    ssl3Ja4ExtensionModeExact = 1
+} ssl3Ja4ExtensionMode;
+
+typedef enum {
+    ssl3Ja4SniUnset = 0,
+    ssl3Ja4SniPresent,
+    ssl3Ja4SniDomain,
+    ssl3Ja4SniNone,
+    ssl3Ja4SniIp
+} ssl3Ja4SniMode;
+
+typedef struct {
+    PRBool strict;
+
+    PRBool hasCipherSuites;
+    unsigned int cipherSuiteCount;
+    ssl3CipherSuite cipherSuites[ssl_V3_SUITES_IMPLEMENTED];
+    PRBool hasCipherMode;
+    ssl3Ja4CipherMode cipherMode;
+
+    PRBool hasAlpn;
+    unsigned int alpnLen;
+    unsigned char alpn[SSL3_JA4_CFG_MAX_ALPN];
+
+    PRBool hasEnableGrease;
+    PRBool enableGrease;
+
+    PRBool greaseValueSet;
+    PRUint16 greaseValue;
+
+    PRBool hasEnableChXtnPermutation;
+    PRBool enableChXtnPermutation;
+
+    PRBool hasTlsMin;
+    PRUint16 tlsMin;
+
+    PRBool hasTlsMax;
+    PRUint16 tlsMax;
+
+    PRBool hasSupportedVersions;
+    unsigned int supportedVersionCount;
+    PRUint16 supportedVersions[SSL3_JA4_CFG_MAX_LIST];
+
+    PRBool hasExtensionOrder;
+    unsigned int extensionCount;
+    PRUint16 extensions[SSL3_JA4_CFG_MAX_LIST];
+    PRBool hasExtensionMode;
+    ssl3Ja4ExtensionMode extensionMode;
+
+    PRBool hasSupportedGroups;
+    unsigned int supportedGroupCount;
+    PRUint16 supportedGroups[SSL3_JA4_CFG_MAX_LIST];
+
+    PRBool hasKeyShareGroups;
+    unsigned int keyShareGroupCount;
+    PRUint16 keyShareGroups[SSL3_JA4_CFG_MAX_LIST];
+
+    PRBool hasPskKeyExchangeModes;
+    unsigned int pskKeyExchangeModeCount;
+    PRUint8 pskKeyExchangeModes[SSL3_JA4_CFG_MAX_LIST];
+
+    PRBool hasSignatureSchemes;
+    unsigned int signatureSchemeCount;
+    SSLSignatureScheme signatureSchemes[MAX_SIGNATURE_SCHEMES];
+
+    PRBool hasSniMode;
+    PRBool sniPresent;
+    ssl3Ja4SniMode sniMode;
+
+    unsigned int unknownKeyCount;
+    char firstUnknownKey[SSL3_JA4_CFG_MAX_UNKNOWN_KEY];
+
+    PRUint32 mismatchMask;
+} ssl3Ja4SlimConfig;
+
+typedef struct {
+    PRUint16 type;
+    unsigned int offset;
+    unsigned int length;
+} ssl3Ja4ExtensionView;
+
+/* JA4 diagnostic mismatch bitmask v1.
+ * Bits frozen by docs/ja4-diagnostic-schema.md; shared with OpenSSL/BoringSSL. */
+typedef enum {
+    ssl3Ja4MismatchParse = 0x0001u,
+    ssl3Ja4MismatchApply = 0x0002u,
+    ssl3Ja4MismatchKeyShareGroups = 0x0004u,
+    ssl3Ja4MismatchSupportedVersions = 0x0008u,
+    ssl3Ja4MismatchUnknownKey = 0x0010u,
+    ssl3Ja4MismatchInvalidConfig = 0x0020u,
+    ssl3Ja4MismatchMissingExtension = 0x0040u,
+    ssl3Ja4MismatchCipherSuites = 0x0080u,
+    ssl3Ja4MismatchAlpn = 0x0100u,
+    ssl3Ja4MismatchSignatureSchemes = 0x0200u,
+    ssl3Ja4MismatchExtensions = 0x0400u,
+    ssl3Ja4MismatchSupportedGroups = 0x0800u,
+    ssl3Ja4MismatchPskKeyExchangeModes = 0x1000u
+} ssl3Ja4Mismatch;
+
+static PRBool
+ssl3_Ja4ParseExtensionBuffer(const sslBuffer *extensionBuf,
+                             ssl3Ja4ExtensionView *out,
+                             unsigned int maxCount,
+                             unsigned int *outCount);
+
+static PRBool
+ssl3_Ja4FindExtension(const sslBuffer *extensionBuf, PRUint16 type,
+                      ssl3Ja4ExtensionView *view);
+
+static SECStatus
+ssl3_Ja4RewriteTls13ExtensionBodies(sslSocket *ss,
+                                    const ssl3Ja4SlimConfig *cfg,
+                                    sslBuffer *extensionBuf);
+
+static PRBool
+ssl3_Ja4UseExtensionModeReorder(const ssl3Ja4SlimConfig *cfg)
+{
+    return !cfg->hasExtensionMode ||
+           cfg->extensionMode == ssl3Ja4ExtensionModeReorder;
+}
+
+static PRBool
+ssl3_Ja4UseExtensionModeExact(const ssl3Ja4SlimConfig *cfg)
+{
+    return cfg->hasExtensionMode &&
+           cfg->extensionMode == ssl3Ja4ExtensionModeExact;
+}
+
+static char *
+ssl3_Ja4Trim(char *s)
+{
+    char *end;
+
+    while (*s && isspace((unsigned char)*s)) {
+        ++s;
+    }
+    if (!*s) {
+        return s;
+    }
+
+    end = s + strlen(s) - 1;
+    while (end > s && isspace((unsigned char)*end)) {
+        *end = '\0';
+        --end;
+    }
+    return s;
+}
+
+static PRBool
+ssl3_Ja4ParseBool(const char *value, PRBool *out)
+{
+    if (!strcmp(value, "1") || !strcmp(value, "true") ||
+        !strcmp(value, "on") || !strcmp(value, "yes")) {
+        *out = PR_TRUE;
+        return PR_TRUE;
+    }
+
+    if (!strcmp(value, "0") || !strcmp(value, "false") ||
+        !strcmp(value, "off") || !strcmp(value, "no")) {
+        *out = PR_FALSE;
+        return PR_TRUE;
+    }
+
+    return PR_FALSE;
+}
+
+static PRBool
+ssl3_Ja4ParseCipherMode(const char *value, ssl3Ja4SlimConfig *cfg)
+{
+    if (!strcmp(value, "reorder")) {
+        cfg->hasCipherMode = PR_TRUE;
+        cfg->cipherMode = ssl3Ja4CipherModeReorder;
+        return PR_TRUE;
+    }
+    if (!strcmp(value, "exact")) {
+        cfg->hasCipherMode = PR_TRUE;
+        cfg->cipherMode = ssl3Ja4CipherModeExact;
+        return PR_TRUE;
+    }
+    return PR_FALSE;
+}
+
+static PRBool
+ssl3_Ja4ParseExtensionMode(const char *value, ssl3Ja4SlimConfig *cfg)
+{
+    if (!strcmp(value, "reorder")) {
+        cfg->hasExtensionMode = PR_TRUE;
+        cfg->extensionMode = ssl3Ja4ExtensionModeReorder;
+        return PR_TRUE;
+    }
+    if (!strcmp(value, "exact")) {
+        cfg->hasExtensionMode = PR_TRUE;
+        cfg->extensionMode = ssl3Ja4ExtensionModeExact;
+        return PR_TRUE;
+    }
+    return PR_FALSE;
+}
+
+static PRBool
+ssl3_Ja4ParseTlsVersion(const char *value, PRUint16 *out)
+{
+    char *endptr;
+    unsigned long v;
+
+    if (!strcmp(value, "1.0")) {
+        *out = SSL_LIBRARY_VERSION_TLS_1_0;
+        return PR_TRUE;
+    }
+    if (!strcmp(value, "1.1")) {
+        *out = SSL_LIBRARY_VERSION_TLS_1_1;
+        return PR_TRUE;
+    }
+    if (!strcmp(value, "1.2")) {
+        *out = SSL_LIBRARY_VERSION_TLS_1_2;
+        return PR_TRUE;
+    }
+    if (!strcmp(value, "1.3")) {
+        *out = SSL_LIBRARY_VERSION_TLS_1_3;
+        return PR_TRUE;
+    }
+
+    v = strtoul(value, &endptr, 0);
+    if (endptr == value || *endptr != '\0' || v > 0xFFFF) {
+        return PR_FALSE;
+    }
+
+    *out = (PRUint16)v;
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParseU16List(char *value, PRUint16 *out, unsigned int maxCount,
+                     unsigned int *outCount)
+{
+    char *cursor = value;
+
+    *outCount = 0;
+
+    while (*cursor) {
+        char *endptr;
+        unsigned long parsed;
+
+        while (*cursor && (isspace((unsigned char)*cursor) || *cursor == ',')) {
+            ++cursor;
+        }
+        if (!*cursor) {
+            break;
+        }
+
+        parsed = strtoul(cursor, &endptr, 0);
+        if (endptr == cursor || parsed > 0xFFFF || *outCount >= maxCount) {
+            return PR_FALSE;
+        }
+        out[(*outCount)++] = (PRUint16)parsed;
+        cursor = endptr;
+
+        while (*cursor && isspace((unsigned char)*cursor)) {
+            ++cursor;
+        }
+        if (*cursor == ',') {
+            ++cursor;
+        } else if (*cursor != '\0') {
+            return PR_FALSE;
+        }
+    }
+
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParseU8List(char *value, PRUint8 *out, unsigned int maxCount,
+                    unsigned int *outCount)
+{
+    char *cursor = value;
+
+    *outCount = 0;
+
+    while (*cursor) {
+        char *endptr;
+        unsigned long parsed;
+
+        while (*cursor && (isspace((unsigned char)*cursor) || *cursor == ',')) {
+            ++cursor;
+        }
+        if (!*cursor) {
+            break;
+        }
+
+        parsed = strtoul(cursor, &endptr, 0);
+        if (endptr == cursor || parsed > 0xFF || *outCount >= maxCount) {
+            return PR_FALSE;
+        }
+        out[(*outCount)++] = (PRUint8)parsed;
+        cursor = endptr;
+
+        while (*cursor && isspace((unsigned char)*cursor)) {
+            ++cursor;
+        }
+        if (*cursor == ',') {
+            ++cursor;
+        } else if (*cursor != '\0') {
+            return PR_FALSE;
+        }
+    }
+
+    return PR_TRUE;
+}
+
+static void
+ssl3_Ja4RememberUnknownKey(ssl3Ja4SlimConfig *cfg, const char *key)
+{
+    ++cfg->unknownKeyCount;
+    cfg->mismatchMask |= ssl3Ja4MismatchUnknownKey;
+    if (!cfg->firstUnknownKey[0]) {
+        PORT_Strncpy(cfg->firstUnknownKey, key, sizeof(cfg->firstUnknownKey) - 1);
+        cfg->firstUnknownKey[sizeof(cfg->firstUnknownKey) - 1] = '\0';
+    }
+}
+
+static PRBool
+ssl3_Ja4ParseCipherSuites(char *value, ssl3Ja4SlimConfig *cfg)
+{
+    PRUint16 parsed[ssl_V3_SUITES_IMPLEMENTED];
+    unsigned int count = 0;
+    unsigned int i;
+
+    if (!ssl3_Ja4ParseU16List(value, parsed, PR_ARRAY_SIZE(parsed), &count)) {
+        return PR_FALSE;
+    }
+
+    cfg->hasCipherSuites = PR_TRUE;
+    cfg->cipherSuiteCount = count;
+    for (i = 0; i < count; ++i) {
+        cfg->cipherSuites[i] = (ssl3CipherSuite)parsed[i];
+    }
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParseAlpn(char *value, ssl3Ja4SlimConfig *cfg)
+{
+    char *cursor = value;
+
+    cfg->hasAlpn = PR_TRUE;
+    cfg->alpnLen = 0;
+
+    while (*cursor) {
+        char *start;
+        char *end;
+        unsigned int len;
+
+        while (*cursor && (isspace((unsigned char)*cursor) || *cursor == ',')) {
+            ++cursor;
+        }
+        if (!*cursor) {
+            break;
+        }
+
+        start = cursor;
+        while (*cursor && *cursor != ',') {
+            ++cursor;
+        }
+        end = cursor;
+        while (end > start && isspace((unsigned char)end[-1])) {
+            --end;
+        }
+
+        len = (unsigned int)(end - start);
+        if (len == 0 || len > 255 ||
+            (cfg->alpnLen + 1 + len) > sizeof(cfg->alpn)) {
+            return PR_FALSE;
+        }
+
+        cfg->alpn[cfg->alpnLen++] = (unsigned char)len;
+        PORT_Memcpy(cfg->alpn + cfg->alpnLen, start, len);
+        cfg->alpnLen += len;
+    }
+
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParseExtensionOrder(char *value, ssl3Ja4SlimConfig *cfg)
+{
+    if (!ssl3_Ja4ParseU16List(value, cfg->extensions, PR_ARRAY_SIZE(cfg->extensions),
+                              &cfg->extensionCount)) {
+        return PR_FALSE;
+    }
+    if (cfg->extensionCount == 0) {
+        return PR_FALSE;
+    }
+
+    cfg->hasExtensionOrder = PR_TRUE;
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParseSupportedVersions(char *value, ssl3Ja4SlimConfig *cfg)
+{
+    if (!ssl3_Ja4ParseU16List(value, cfg->supportedVersions,
+                              PR_ARRAY_SIZE(cfg->supportedVersions),
+                              &cfg->supportedVersionCount)) {
+        return PR_FALSE;
+    }
+    if (cfg->supportedVersionCount == 0) {
+        return PR_FALSE;
+    }
+
+    cfg->hasSupportedVersions = PR_TRUE;
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParseSupportedGroups(char *value, ssl3Ja4SlimConfig *cfg)
+{
+    if (!ssl3_Ja4ParseU16List(value, cfg->supportedGroups,
+                              PR_ARRAY_SIZE(cfg->supportedGroups),
+                              &cfg->supportedGroupCount)) {
+        return PR_FALSE;
+    }
+    if (cfg->supportedGroupCount == 0) {
+        return PR_FALSE;
+    }
+
+    cfg->hasSupportedGroups = PR_TRUE;
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParseKeyShareGroups(char *value, ssl3Ja4SlimConfig *cfg)
+{
+    if (!ssl3_Ja4ParseU16List(value, cfg->keyShareGroups,
+                              PR_ARRAY_SIZE(cfg->keyShareGroups),
+                              &cfg->keyShareGroupCount)) {
+        return PR_FALSE;
+    }
+    if (cfg->keyShareGroupCount == 0) {
+        return PR_FALSE;
+    }
+
+    cfg->hasKeyShareGroups = PR_TRUE;
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParsePskKeyExchangeModes(char *value, ssl3Ja4SlimConfig *cfg)
+{
+    if (!ssl3_Ja4ParseU8List(value, cfg->pskKeyExchangeModes,
+                             PR_ARRAY_SIZE(cfg->pskKeyExchangeModes),
+                             &cfg->pskKeyExchangeModeCount)) {
+        return PR_FALSE;
+    }
+    if (cfg->pskKeyExchangeModeCount == 0) {
+        return PR_FALSE;
+    }
+
+    cfg->hasPskKeyExchangeModes = PR_TRUE;
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParseSignatureSchemes(char *value, ssl3Ja4SlimConfig *cfg)
+{
+    PRUint16 parsed[MAX_SIGNATURE_SCHEMES];
+    unsigned int count = 0;
+    unsigned int i;
+
+    if (!ssl3_Ja4ParseU16List(value, parsed, PR_ARRAY_SIZE(parsed), &count)) {
+        return PR_FALSE;
+    }
+
+    cfg->hasSignatureSchemes = PR_TRUE;
+    cfg->signatureSchemeCount = 0;
+    for (i = 0; i < count; ++i) {
+        SSLSignatureScheme scheme = (SSLSignatureScheme)parsed[i];
+        if (ssl_IsSupportedSignatureScheme(scheme)) {
+            cfg->signatureSchemes[cfg->signatureSchemeCount++] = scheme;
+        }
+    }
+
+    return cfg->signatureSchemeCount > 0;
+}
+
+static const char *
+ssl3_Ja4SniModeStr(ssl3Ja4SniMode mode)
+{
+    switch (mode) {
+        case ssl3Ja4SniPresent:
+            return "present";
+        case ssl3Ja4SniDomain:
+            return "domain";
+        case ssl3Ja4SniNone:
+            return "none";
+        case ssl3Ja4SniIp:
+            return "ip";
+        case ssl3Ja4SniUnset:
+            break;
+    }
+    return "unset";
+}
+
+static PRBool
+ssl3_Ja4SniModeEmit(ssl3Ja4SniMode mode)
+{
+    return mode == ssl3Ja4SniPresent ||
+           mode == ssl3Ja4SniDomain ||
+           mode == ssl3Ja4SniIp;
+}
+
+static PRBool
+ssl3_Ja4ParseSniMode(const char *value, ssl3Ja4SlimConfig *cfg)
+{
+    ssl3Ja4SniMode mode;
+    if (!strcmp(value, "present")) {
+        mode = ssl3Ja4SniPresent;
+    } else if (!strcmp(value, "domain")) {
+        mode = ssl3Ja4SniDomain;
+    } else if (!strcmp(value, "none")) {
+        mode = ssl3Ja4SniNone;
+    } else if (!strcmp(value, "ip")) {
+        mode = ssl3Ja4SniIp;
+    } else {
+        return PR_FALSE;
+    }
+    cfg->hasSniMode = PR_TRUE;
+    cfg->sniMode = mode;
+    cfg->sniPresent = ssl3_Ja4SniModeEmit(mode);
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ParseConfigEntry(ssl3Ja4SlimConfig *cfg, const char *key, char *value)
+{
+    PRBool parsedBool;
+    PRUint16 parsedVersion;
+
+    if (!strcmp(key, "cipher_suites")) {
+        return ssl3_Ja4ParseCipherSuites(value, cfg);
+    }
+
+    if (!strcmp(key, "cipher_mode")) {
+        return ssl3_Ja4ParseCipherMode(value, cfg);
+    }
+
+    if (!strcmp(key, "alpn")) {
+        return ssl3_Ja4ParseAlpn(value, cfg);
+    }
+
+    if (!strcmp(key, "extension_order") || !strcmp(key, "extensions")) {
+        return ssl3_Ja4ParseExtensionOrder(value, cfg);
+    }
+
+    if (!strcmp(key, "extension_mode")) {
+        return ssl3_Ja4ParseExtensionMode(value, cfg);
+    }
+
+    if (!strcmp(key, "signature_algorithms") || !strcmp(key, "signature_schemes")) {
+        return ssl3_Ja4ParseSignatureSchemes(value, cfg);
+    }
+
+    if (!strcmp(key, "sni_mode")) {
+        return ssl3_Ja4ParseSniMode(value, cfg);
+    }
+
+    if (!strcmp(key, "enable_ch_xtn_permutation")) {
+        if (!ssl3_Ja4ParseBool(value, &parsedBool)) {
+            return PR_FALSE;
+        }
+        cfg->hasEnableChXtnPermutation = PR_TRUE;
+        cfg->enableChXtnPermutation = parsedBool;
+        return PR_TRUE;
+    }
+
+    if (!strcmp(key, "enable_grease")) {
+        if (!ssl3_Ja4ParseBool(value, &parsedBool)) {
+            return PR_FALSE;
+        }
+        cfg->hasEnableGrease = PR_TRUE;
+        cfg->enableGrease = parsedBool;
+        return PR_TRUE;
+    }
+
+    if (!strcmp(key, "grease_value")) {
+        char *endptr;
+        unsigned long parsed = strtoul(value, &endptr, 0);
+        if (endptr == value || *endptr != '\0' || parsed > 0xFFFFu) {
+            return PR_FALSE;
+        }
+        cfg->greaseValueSet = PR_TRUE;
+        cfg->greaseValue = (PRUint16)parsed;
+        return PR_TRUE;
+    }
+
+    if (!strcmp(key, "strict")) {
+        if (!ssl3_Ja4ParseBool(value, &parsedBool)) {
+            return PR_FALSE;
+        }
+        cfg->strict = parsedBool;
+        return PR_TRUE;
+    }
+
+    if (!strcmp(key, "tls_min")) {
+        if (!ssl3_Ja4ParseTlsVersion(value, &parsedVersion)) {
+            return PR_FALSE;
+        }
+        cfg->hasTlsMin = PR_TRUE;
+        cfg->tlsMin = parsedVersion;
+        return PR_TRUE;
+    }
+
+    if (!strcmp(key, "tls_max")) {
+        if (!ssl3_Ja4ParseTlsVersion(value, &parsedVersion)) {
+            return PR_FALSE;
+        }
+        cfg->hasTlsMax = PR_TRUE;
+        cfg->tlsMax = parsedVersion;
+        return PR_TRUE;
+    }
+
+    if (!strcmp(key, "supported_versions")) {
+        return ssl3_Ja4ParseSupportedVersions(value, cfg);
+    }
+
+    if (!strcmp(key, "supported_groups")) {
+        return ssl3_Ja4ParseSupportedGroups(value, cfg);
+    }
+
+    if (!strcmp(key, "key_share_groups")) {
+        return ssl3_Ja4ParseKeyShareGroups(value, cfg);
+    }
+
+    if (!strcmp(key, "psk_key_exchange_modes")) {
+        return ssl3_Ja4ParsePskKeyExchangeModes(value, cfg);
+    }
+
+    ssl3_Ja4RememberUnknownKey(cfg, key);
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4ValidateConfig(ssl3Ja4SlimConfig *cfg)
+{
+    unsigned int i;
+
+    if (cfg->hasTlsMin && cfg->hasTlsMax && cfg->tlsMin > cfg->tlsMax) {
+        cfg->mismatchMask |= ssl3Ja4MismatchInvalidConfig;
+        return PR_FALSE;
+    }
+
+    if (cfg->strict && cfg->unknownKeyCount) {
+        return PR_FALSE;
+    }
+
+    if (cfg->hasCipherMode &&
+        cfg->cipherMode == ssl3Ja4CipherModeExact &&
+        (!cfg->hasCipherSuites || cfg->cipherSuiteCount == 0)) {
+        cfg->mismatchMask |= ssl3Ja4MismatchInvalidConfig;
+        return PR_FALSE;
+    }
+
+    if (cfg->hasExtensionMode &&
+        cfg->extensionMode == ssl3Ja4ExtensionModeExact &&
+        !cfg->hasExtensionOrder) {
+        cfg->mismatchMask |= ssl3Ja4MismatchInvalidConfig;
+        return PR_FALSE;
+    }
+
+    for (i = 0; i < cfg->supportedGroupCount; ++i) {
+        if (!ssl_LookupNamedGroup((SSLNamedGroup)cfg->supportedGroups[i])) {
+            return PR_FALSE;
+        }
+    }
+
+    for (i = 0; i < cfg->keyShareGroupCount; ++i) {
+        if (!ssl_LookupNamedGroup((SSLNamedGroup)cfg->keyShareGroups[i])) {
+            return PR_FALSE;
+        }
+    }
+
+    if (cfg->hasSupportedGroups && cfg->hasKeyShareGroups) {
+        for (i = 0; i < cfg->keyShareGroupCount; ++i) {
+            unsigned int j;
+            PRBool found = PR_FALSE;
+            for (j = 0; j < cfg->supportedGroupCount; ++j) {
+                if (cfg->keyShareGroups[i] == cfg->supportedGroups[j]) {
+                    found = PR_TRUE;
+                    break;
+                }
+            }
+            if (!found) {
+                cfg->mismatchMask |= ssl3Ja4MismatchInvalidConfig;
+                return PR_FALSE;
+            }
+        }
+    }
+
+    /* Phase 2 dependency closure: when a body override is configured but the
+     * corresponding extension id is missing from an explicit
+     * requested_extension_order, silently append it (before any pre_shared_key
+     * entry, since PSK must remain last per RFC 8446 sec. 4.2.11). Without
+     * this, a config like supported_versions=... combined with
+     * extension_mode=exact would raise ssl3Ja4MismatchExtensions even though
+     * the missing id is fully implied by the rest of the config. */
+    if (cfg->hasExtensionOrder) {
+        static const PRUint16 kClosureTypes[] = {
+            0x000d, /* signature_algorithms     <- hasSignatureSchemes */
+            0x000a, /* supported_groups         <- hasSupportedGroups */
+            0x0033, /* key_share                <- hasKeyShareGroups */
+            0x002b, /* supported_versions       <- hasSupportedVersions */
+            0x002d, /* psk_key_exchange_modes   <- hasPskKeyExchangeModes */
+            0x0010, /* alpn                     <- hasAlpn */
+            0x0000  /* server_name              <- hasSniMode && sniPresent */
+        };
+        PRBool needed[PR_ARRAY_SIZE(kClosureTypes)];
+        unsigned int c;
+
+        needed[0] = cfg->hasSignatureSchemes;
+        needed[1] = cfg->hasSupportedGroups;
+        needed[2] = cfg->hasKeyShareGroups;
+        needed[3] = cfg->hasSupportedVersions;
+        needed[4] = cfg->hasPskKeyExchangeModes;
+        needed[5] = cfg->hasAlpn;
+        needed[6] = cfg->hasSniMode && cfg->sniPresent;
+
+        for (c = 0; c < PR_ARRAY_SIZE(kClosureTypes); ++c) {
+            PRBool already;
+            unsigned int k;
+            unsigned int insertAt;
+
+            if (!needed[c]) {
+                continue;
+            }
+            already = PR_FALSE;
+            for (k = 0; k < cfg->extensionCount; ++k) {
+                if (cfg->extensions[k] == kClosureTypes[c]) {
+                    already = PR_TRUE;
+                    break;
+                }
+            }
+            if (already) {
+                continue;
+            }
+            if (cfg->extensionCount >= PR_ARRAY_SIZE(cfg->extensions)) {
+                break;
+            }
+            insertAt = cfg->extensionCount;
+            for (k = 0; k < cfg->extensionCount; ++k) {
+                if (cfg->extensions[k] == ssl_tls13_pre_shared_key_xtn) {
+                    insertAt = k;
+                    break;
+                }
+            }
+            for (k = cfg->extensionCount; k > insertAt; --k) {
+                cfg->extensions[k] = cfg->extensions[k - 1];
+            }
+            cfg->extensions[insertAt] = kClosureTypes[c];
+            ++cfg->extensionCount;
+        }
+    }
+
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4LoadConfig(const char *path, ssl3Ja4SlimConfig *cfg)
+{
+    FILE *fp;
+    char line[4096];
+
+    PORT_Memset(cfg, 0, sizeof(*cfg));
+
+    fp = fopen(path, "r");
+    if (!fp) {
+        return PR_FALSE;
+    }
+
+    while (fgets(line, sizeof(line), fp)) {
+        char *key;
+        char *value;
+        char *sep;
+
+        key = ssl3_Ja4Trim(line);
+        if (!*key || *key == '#') {
+            continue;
+        }
+
+        sep = strchr(key, '=');
+        if (!sep) {
+            continue;
+        }
+        *sep = '\0';
+
+        key = ssl3_Ja4Trim(key);
+        value = ssl3_Ja4Trim(sep + 1);
+        if (!ssl3_Ja4ParseConfigEntry(cfg, key, value)) {
+            fclose(fp);
+            return PR_FALSE;
+        }
+    }
+
+    fclose(fp);
+    return ssl3_Ja4ValidateConfig(cfg);
+}
+
+static void
+ssl3_Ja4ApplyCipherOrderReorder(sslSocket *ss, const ssl3Ja4SlimConfig *cfg)
+{
+    ssl3CipherSuiteCfg reordered[ssl_V3_SUITES_IMPLEMENTED];
+    PRBool used[ssl_V3_SUITES_IMPLEMENTED];
+    unsigned int i;
+    unsigned int j;
+    unsigned int out = 0;
+
+    if (!cfg->hasCipherSuites || cfg->cipherSuiteCount == 0) {
+        return;
+    }
+
+    PORT_Memset(used, 0, sizeof(used));
+
+    for (i = 0; i < cfg->cipherSuiteCount; ++i) {
+        for (j = 0; j < ssl_V3_SUITES_IMPLEMENTED; ++j) {
+            if (!used[j] &&
+                ss->cipherSuites[j].cipher_suite == cfg->cipherSuites[i]) {
+                reordered[out++] = ss->cipherSuites[j];
+                used[j] = PR_TRUE;
+                break;
+            }
+        }
+    }
+
+    for (j = 0; j < ssl_V3_SUITES_IMPLEMENTED; ++j) {
+        if (!used[j]) {
+            reordered[out++] = ss->cipherSuites[j];
+        }
+    }
+
+    if (out == ssl_V3_SUITES_IMPLEMENTED) {
+        PORT_Memcpy(ss->cipherSuites, reordered, sizeof(reordered));
+    }
+}
+
+static void
+ssl3_Ja4ApplyCipherOrderExact(sslSocket *ss, const ssl3Ja4SlimConfig *cfg)
+{
+    ssl3CipherSuiteCfg reordered[ssl_V3_SUITES_IMPLEMENTED];
+    PRBool used[ssl_V3_SUITES_IMPLEMENTED];
+    unsigned int i;
+    unsigned int j;
+    unsigned int out = 0;
+
+    if (!cfg->hasCipherSuites || cfg->cipherSuiteCount == 0) {
+        return;
+    }
+
+    PORT_Memset(used, 0, sizeof(used));
+
+    for (i = 0; i < cfg->cipherSuiteCount; ++i) {
+        for (j = 0; j < ssl_V3_SUITES_IMPLEMENTED; ++j) {
+            if (!used[j] &&
+                ss->cipherSuites[j].cipher_suite == cfg->cipherSuites[i]) {
+                reordered[out++] = ss->cipherSuites[j];
+                reordered[out - 1].enabled = 1;
+                /* Exact replay is expected to resurrect explicitly requested
+                 * suites even when NSS policy initialization disabled them by
+                 * default. Keep this scoped to the JA4 exact-mode path rather
+                 * than mutating global policy. */
+                reordered[out - 1].policy = SSL_ALLOWED;
+                used[j] = PR_TRUE;
+                break;
+            }
+        }
+    }
+
+    for (j = 0; j < ssl_V3_SUITES_IMPLEMENTED; ++j) {
+        if (!used[j]) {
+            reordered[out++] = ss->cipherSuites[j];
+            reordered[out - 1].enabled = 0;
+        }
+    }
+
+    if (out == ssl_V3_SUITES_IMPLEMENTED) {
+        PORT_Memcpy(ss->cipherSuites, reordered, sizeof(reordered));
+    }
+}
