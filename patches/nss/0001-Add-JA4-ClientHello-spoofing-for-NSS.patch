+static void
+ssl3_Ja4SyncXtnDataFromBuffer(sslSocket *ss, const sslBuffer *extensionBuf)
+{
+    ssl3Ja4ExtensionView parsed[SSL3_JA4_CFG_MAX_LIST];
+    unsigned int parsedCount = 0;
+    unsigned int i;
+
+    ss->xtnData.numAdvertised = 0;
+    ss->xtnData.lastXtnOffset = 0;
+    ss->xtnData.echXtnOffset = 0;
+
+    if (!ssl3_Ja4ParseExtensionBuffer(extensionBuf, parsed, PR_ARRAY_SIZE(parsed),
+                                      &parsedCount)) {
+        return;
+    }
+
+    for (i = 0; i < parsedCount; ++i) {
+        ss->xtnData.advertised[ss->xtnData.numAdvertised++] = parsed[i].type;
+        if (parsed[i].type == ssl_tls13_pre_shared_key_xtn) {
+            ss->xtnData.lastXtnOffset = parsed[i].offset;
+        }
+        if (parsed[i].type == ssl_tls13_encrypted_client_hello_xtn) {
+            ss->xtnData.echXtnOffset = parsed[i].offset;
+        }
+    }
+}
