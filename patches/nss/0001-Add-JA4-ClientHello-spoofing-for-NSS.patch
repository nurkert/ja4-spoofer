+static PRBool
+ssl3_Ja4CollectEffectiveCipherSuites(sslSocket *ss, PRUint16 *out,
+                                     unsigned int maxCount,
+                                     unsigned int *outCount)
+{
+    unsigned int i;
+
+    *outCount = 0;
+    for (i = 0; i < ssl_V3_SUITES_IMPLEMENTED; ++i) {
+        ssl3CipherSuiteCfg *suite = &ss->cipherSuites[i];
+        if (!ssl3_config_match(suite, ss->ssl3.policy, &ss->vrange, ss)) {
+            continue;
+        }
+        if (*outCount >= maxCount) {
+            return PR_FALSE;
+        }
+        out[(*outCount)++] = suite->cipher_suite;
+    }
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4CollectEffectiveExtensionTypes(const sslBuffer *extensionBuf, PRUint16 *out,
+                                       unsigned int maxCount,
+                                       unsigned int *outCount)
+{
+    ssl3Ja4ExtensionView parsed[SSL3_JA4_CFG_MAX_LIST];
+    unsigned int parsedCount = 0;
+    unsigned int i;
+
+    if (!ssl3_Ja4ParseExtensionBuffer(extensionBuf, parsed, PR_ARRAY_SIZE(parsed),
+                                      &parsedCount)) {
+        return PR_FALSE;
+    }
+    if (parsedCount > maxCount) {
+        return PR_FALSE;
+    }
+
+    for (i = 0; i < parsedCount; ++i) {
+        out[i] = parsed[i].type;
+    }
+    *outCount = parsedCount;
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4CompareU16Lists(const PRUint16 *left, unsigned int leftCount,
+                        const PRUint16 *right, unsigned int rightCount)
+{
+    unsigned int i;
+
+    if (leftCount != rightCount) {
+        return PR_FALSE;
+    }
+    for (i = 0; i < leftCount; ++i) {
+        if (left[i] != right[i]) {
+            return PR_FALSE;
+        }
+    }
+    return PR_TRUE;
+}
