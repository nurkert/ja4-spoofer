+static void
+ssl3_Ja4DumpU8List(FILE *fp, const PRUint8 *values, unsigned int count)
+{
+    unsigned int i;
+
+    for (i = 0; i < count; ++i) {
+        if (i) {
+            fputc(',', fp);
+        }
+        fprintf(fp, "%u", (unsigned int)values[i]);
+    }
