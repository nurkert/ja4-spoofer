+static SECStatus
+ssl3_Ja4BuildSupportedVersionsBody(const sslSocket *ss,
+                                   const ssl3Ja4SlimConfig *cfg,
+                                   sslBuffer *body)
+{
+    unsigned int i;
+
+    if (sslBuffer_AppendNumber(body, cfg->supportedVersionCount * 2, 1) !=
+        SECSuccess) {
+        return SECFailure;
+    }
+
+    for (i = 0; i < cfg->supportedVersionCount; ++i) {
+        PRUint16 wire = tls13_EncodeVersion(cfg->supportedVersions[i],
+                                            ss->protocolVariant);
+        if (sslBuffer_AppendNumber(body, wire, 2) != SECSuccess) {
+            return SECFailure;
+        }
+    }
+
+    return SECSuccess;
+}
+
+static SECStatus
+ssl3_Ja4BuildSupportedGroupsBody(const ssl3Ja4SlimConfig *cfg, sslBuffer *body)
+{
+    unsigned int i;
+
+    if (sslBuffer_AppendNumber(body, cfg->supportedGroupCount * 2, 2) !=
+        SECSuccess) {
+        return SECFailure;
+    }
+
+    for (i = 0; i < cfg->supportedGroupCount; ++i) {
+        if (sslBuffer_AppendNumber(body, cfg->supportedGroups[i], 2) !=
+            SECSuccess) {
+            return SECFailure;
+        }
+    }
+
+    return SECSuccess;
+}
+
+static SECStatus
+ssl3_Ja4BuildPskModesBody(const ssl3Ja4SlimConfig *cfg, sslBuffer *body)
+{
+    if (sslBuffer_AppendNumber(body, cfg->pskKeyExchangeModeCount, 1) !=
+        SECSuccess) {
+        return SECFailure;
+    }
+    if (sslBuffer_Append(body, cfg->pskKeyExchangeModes,
+                         cfg->pskKeyExchangeModeCount) != SECSuccess) {
+        return SECFailure;
+    }
+    return SECSuccess;
+}
+
+static sslEphemeralKeyPair *
+ssl3_Ja4FindEphemeralKeyPair(sslSocket *ss, PRUint16 group)
+{
+    PRCList *cursor;
+
+    for (cursor = PR_NEXT_LINK(&ss->ephemeralKeyPairs);
+         cursor != &ss->ephemeralKeyPairs;
+         cursor = PR_NEXT_LINK(cursor)) {
+        sslEphemeralKeyPair *keyPair = (sslEphemeralKeyPair *)cursor;
+        if (keyPair->group && keyPair->group->name == group) {
+            return keyPair;
+        }
+    }
+
+    return NULL;
+}
+
+static SECStatus
+ssl3_Ja4BuildKeyShareBody(sslSocket *ss, const ssl3Ja4SlimConfig *cfg,
+                          sslBuffer *body)
+{
+    sslBuffer entries = SSL_BUFFER_EMPTY;
+    unsigned int i;
+
+    for (i = 0; i < cfg->keyShareGroupCount; ++i) {
+        sslEphemeralKeyPair *keyPair =
+            ssl3_Ja4FindEphemeralKeyPair(ss, cfg->keyShareGroups[i]);
+        if (!keyPair) {
+            goto loser;
+        }
+        if (tls13_EncodeKeyShareEntry(&entries, keyPair) != SECSuccess) {
+            goto loser;
+        }
+    }
+
+    if (sslBuffer_AppendNumber(body, entries.len, 2) != SECSuccess ||
+        sslBuffer_AppendBuffer(body, &entries) != SECSuccess) {
+        goto loser;
+    }
+
+    sslBuffer_Clear(&entries);
+    return SECSuccess;
+
+loser:
+    sslBuffer_Clear(&entries);
+    return SECFailure;
+}
+
+static SECStatus
+ssl3_Ja4RewriteTls13ExtensionBodies(sslSocket *ss,
+                                    const ssl3Ja4SlimConfig *cfg,
+                                    sslBuffer *extensionBuf)
+{
+    sslBuffer body = SSL_BUFFER_EMPTY;
+
+    if (cfg->hasSupportedVersions) {
+        if (ssl3_Ja4BuildSupportedVersionsBody(ss, cfg, &body) != SECSuccess ||
+            ssl3_Ja4ReplaceExtensionBody(extensionBuf,
+                                         ssl_tls13_supported_versions_xtn,
+                                         body.buf, body.len) != SECSuccess) {
+            goto loser;
+        }
+        sslBuffer_Clear(&body);
+    }
+
+    if (cfg->hasSupportedGroups) {
+        if (ssl3_Ja4BuildSupportedGroupsBody(cfg, &body) != SECSuccess ||
+            ssl3_Ja4ReplaceExtensionBody(extensionBuf, ssl_supported_groups_xtn,
+                                         body.buf, body.len) != SECSuccess) {
+            goto loser;
+        }
+        sslBuffer_Clear(&body);
+    }
+
+    if (cfg->hasPskKeyExchangeModes) {
+        if (ssl3_Ja4BuildPskModesBody(cfg, &body) != SECSuccess ||
+            ssl3_Ja4ReplaceExtensionBody(extensionBuf,
+                                         ssl_tls13_psk_key_exchange_modes_xtn,
+                                         body.buf, body.len) != SECSuccess) {
+            goto loser;
+        }
+        sslBuffer_Clear(&body);
+    }
+
+    if (cfg->hasKeyShareGroups) {
+        if (ssl3_Ja4BuildKeyShareBody(ss, cfg, &body) != SECSuccess ||
+            ssl3_Ja4ReplaceExtensionBody(extensionBuf, ssl_tls13_key_share_xtn,
+                                         body.buf, body.len) != SECSuccess) {
+            goto loser;
+        }
+        sslBuffer_Clear(&body);
+    }
+
+    return SECSuccess;
+
+loser:
+    sslBuffer_Clear(&body);
+    return SECFailure;
+}
+
+static SECStatus
+ssl3_Ja4RewriteClientExtensions(sslSocket *ss, const ssl3Ja4SlimConfig *cfg,
+                                sslBuffer *extensionBuf)
+{
+    ssl3Ja4ExtensionView parsed[SSL3_JA4_CFG_MAX_LIST];
+    PRBool used[SSL3_JA4_CFG_MAX_LIST];
+    sslBuffer rewritten = SSL_BUFFER_EMPTY;
+    unsigned int parsedCount = 0;
+    unsigned int i;
+    unsigned int j;
+    PRBool hasSniInOutput = PR_FALSE;
+
+    if (!cfg->hasExtensionOrder && !cfg->hasSniMode) {
+        return SECSuccess;
+    }
+
+    if (!ssl3_Ja4ParseExtensionBuffer(extensionBuf, parsed, PR_ARRAY_SIZE(parsed),
+                                      &parsedCount)) {
+        return SECFailure;
+    }
+    PORT_Memset(used, 0, sizeof(used));
+
+    if (cfg->hasExtensionOrder) {
+        for (i = 0; i < cfg->extensionCount; ++i) {
+            PRBool found = PR_FALSE;
+            for (j = 0; j < parsedCount; ++j) {
+                if (used[j] || parsed[j].type != cfg->extensions[i]) {
+                    continue;
+                }
+                used[j] = PR_TRUE;
+                found = PR_TRUE;
+                if (cfg->hasSniMode && !cfg->sniPresent &&
+                    parsed[j].type == ssl_server_name_xtn) {
+                    break;
+                }
+                if (sslBuffer_Append(&rewritten,
+                                     extensionBuf->buf + parsed[j].offset,
+                                     parsed[j].length) != SECSuccess) {
+                    goto loser;
+                }
+                if (parsed[j].type == ssl_server_name_xtn) {
+                    hasSniInOutput = PR_TRUE;
+                }
+                break;
+            }
+            /* JA4 EXACT-mode synthetic stub: the user listed an extension
+             * type that NSS' clientHelloSendersTLS[] dispatcher did not
+             * produce. Write a length-0 body so the JA4_c hash sees the
+             * type appear in the right position. TLS 1.3 servers must
+             * ignore unknown ClientHello extensions (RFC 8446 4.2); TLS
+             * 1.2 ignores unknown client extensions silently. If a buggy
+             * server echoes one back, ssl3_HandleUnknownExtension drops
+             * it. SNI is exempt — its body is mandatory and would never
+             * be a synthetic candidate (NSS always produces it when
+             * needed). */
+            if (!found && ssl3_Ja4UseExtensionModeExact(cfg) &&
+                cfg->extensions[i] != ssl_server_name_xtn) {
+                if (sslBuffer_AppendNumber(&rewritten, cfg->extensions[i],
+                                           2) != SECSuccess ||
+                    sslBuffer_AppendNumber(&rewritten, 0, 2) != SECSuccess) {
+                    goto loser;
+                }
+            }
+        }
+
+        if (ssl3_Ja4UseExtensionModeReorder(cfg)) {
+            for (j = 0; j < parsedCount; ++j) {
+                if (used[j]) {
+                    continue;
+                }
+                if (cfg->hasSniMode && !cfg->sniPresent &&
+                    parsed[j].type == ssl_server_name_xtn) {
+                    continue;
+                }
+                if (sslBuffer_Append(&rewritten,
+                                     extensionBuf->buf + parsed[j].offset,
+                                     parsed[j].length) != SECSuccess) {
+                    goto loser;
+                }
+                if (parsed[j].type == ssl_server_name_xtn) {
+                    hasSniInOutput = PR_TRUE;
+                }
+            }
+        }
+
+        if (cfg->hasSniMode && cfg->sniPresent && !hasSniInOutput) {
+            for (j = 0; j < parsedCount; ++j) {
+                if (used[j] || parsed[j].type != ssl_server_name_xtn) {
+                    continue;
+                }
+                if (sslBuffer_Append(&rewritten,
+                                     extensionBuf->buf + parsed[j].offset,
+                                     parsed[j].length) != SECSuccess) {
+                    goto loser;
+                }
+                hasSniInOutput = PR_TRUE;
+                break;
+            }
+        }
+    } else {
+        for (j = 0; j < parsedCount; ++j) {
+            if (cfg->hasSniMode && !cfg->sniPresent &&
+                parsed[j].type == ssl_server_name_xtn) {
+                continue;
+            }
+            if (sslBuffer_Append(&rewritten,
+                                 extensionBuf->buf + parsed[j].offset,
+                                 parsed[j].length) != SECSuccess) {
+                goto loser;
+            }
+        }
+    }
+
+    sslBuffer_Clear(extensionBuf);
+    *extensionBuf = rewritten;
+    ssl3_Ja4SyncXtnDataFromBuffer(ss, extensionBuf);
+    return SECSuccess;
+
+loser:
+    sslBuffer_Clear(&rewritten);
+    return SECFailure;
+}
+
+static SECStatus
+ssl3_Ja4EnsurePskExtensionLast(sslBuffer *extensionBuf)
+{
+    ssl3Ja4ExtensionView view;
+    sslBuffer rewritten = SSL_BUFFER_EMPTY;
+    unsigned int tailOffset;
+    unsigned int tailLen;
+
+    if (!ssl3_Ja4FindExtension(extensionBuf, ssl_tls13_pre_shared_key_xtn,
+                               &view)) {
+        return SECSuccess;
+    }
+
+    tailOffset = view.offset + view.length;
+    if (tailOffset == extensionBuf->len) {
+        return SECSuccess;
+    }
+
+    tailLen = extensionBuf->len - tailOffset;
+    if (view.offset &&
+        sslBuffer_Append(&rewritten, extensionBuf->buf, view.offset) !=
+            SECSuccess) {
+        goto loser;
+    }
+    if (tailLen &&
+        sslBuffer_Append(&rewritten, extensionBuf->buf + tailOffset, tailLen) !=
+            SECSuccess) {
+        goto loser;
+    }
+    if (sslBuffer_Append(&rewritten, extensionBuf->buf + view.offset,
+                         view.length) != SECSuccess) {
+        goto loser;
+    }
+
+    sslBuffer_Clear(extensionBuf);
+    *extensionBuf = rewritten;
+    return SECSuccess;
+
+loser:
+    sslBuffer_Clear(&rewritten);
+    return SECFailure;
+}
+
+static SECStatus
+ssl3_Ja4FinalizeClientExtensions(sslSocket *ss,
+                                 const ssl3Ja4SlimConfig *cfg,
+                                 sslBuffer *extensionBuf)
+{
+    if (cfg->hasExtensionOrder || cfg->hasSniMode) {
+        if (ssl3_Ja4RewriteClientExtensions(ss, cfg, extensionBuf) !=
+            SECSuccess) {
+            return SECFailure;
+        }
+    }
+
+    if (ssl3_Ja4EnsurePskExtensionLast(extensionBuf) != SECSuccess) {
+        return SECFailure;
+    }
+
+    ssl3_Ja4SyncXtnDataFromBuffer(ss, extensionBuf);
+    return SECSuccess;
+}
+
+static void
+ssl3_Ja4ApplySocketConfig(sslSocket *ss, const ssl3Ja4SlimConfig *cfg)
+{
+    PRUint16 minVersion;
+    PRUint16 maxVersion;
+    SECItem *item;
+    unsigned int i;
+
+    if (cfg->hasCipherSuites) {
+        if (cfg->hasCipherMode && cfg->cipherMode == ssl3Ja4CipherModeExact) {
+            ssl3_Ja4ApplyCipherOrderExact(ss, cfg);
+        } else {
+            ssl3_Ja4ApplyCipherOrderReorder(ss, cfg);
+        }
+    }
+
+    if (cfg->hasSignatureSchemes) {
+        ss->ssl3.signatureSchemeCount = cfg->signatureSchemeCount;
+        PORT_Memcpy(ss->ssl3.signatureSchemes, cfg->signatureSchemes,
+                    cfg->signatureSchemeCount * sizeof(cfg->signatureSchemes[0]));
+    }
+
+    if (cfg->hasAlpn) {
+        SECITEM_FreeItem(&ss->opt.nextProtoNego, PR_FALSE);
+        ss->opt.enableALPN = PR_FALSE;
+
+        if (cfg->alpnLen) {
+            item = SECITEM_AllocItem(NULL, &ss->opt.nextProtoNego, cfg->alpnLen);
+            if (item && item->data) {
+                PORT_Memcpy(ss->opt.nextProtoNego.data, cfg->alpn, cfg->alpnLen);
+                ss->opt.enableALPN = PR_TRUE;
+            }
+        }
+    }
+
+    if (cfg->hasEnableGrease) {
+        ss->opt.enableGrease = cfg->enableGrease;
+    }
+    if (cfg->hasEnableChXtnPermutation) {
+        ss->opt.enableChXtnPermutation = cfg->enableChXtnPermutation;
+    }
+
+    minVersion = cfg->hasTlsMin ? cfg->tlsMin : ss->vrange.min;
+    maxVersion = cfg->hasTlsMax ? cfg->tlsMax : ss->vrange.max;
+    if (minVersion <= maxVersion) {
+        ss->vrange.min = minVersion;
+        ss->vrange.max = maxVersion;
+    }
+
+    if (cfg->hasSupportedGroups || cfg->hasKeyShareGroups) {
+        unsigned int prefCount = 0;
+        unsigned int sourceCount = cfg->hasSupportedGroups ? cfg->supportedGroupCount
+                                                           : cfg->keyShareGroupCount;
+        const PRUint16 *source = cfg->hasSupportedGroups ? cfg->supportedGroups
+                                                         : cfg->keyShareGroups;
+
+        for (i = 0; i < SSL_NAMED_GROUP_COUNT; ++i) {
+            ss->namedGroupPreferences[i] = NULL;
+        }
+
+        for (i = 0; i < sourceCount && prefCount < SSL_NAMED_GROUP_COUNT; ++i) {
+            const sslNamedGroupDef *group =
+                ssl_LookupNamedGroup((SSLNamedGroup)source[i]);
+            if (!group) {
+                continue;
+            }
+            ss->namedGroupPreferences[prefCount++] = group;
+        }
+
+        ss->additionalShares = cfg->hasKeyShareGroups && prefCount
+                                   ? (prefCount - 1)
+                                   : 0;
+    }
+}
+
+/* Replace the random GREASE values that NSS produced in
+ * tls13_ClientGreaseSetup() with the deterministic value derived from
+ * cfg->greaseValue (analogous to BoringSSL's ssl_get_grease_value). The
+ * derivation matches NSS' own slot encoding: slot = (greaseValue & 0xf0) | 0x0a
+ * and ((slot << 8) | slot) is written into every slot. NSS still requires the
+ * two ClientHello GREASE extension slots to differ, so we keep the existing
+ * disambiguation (XOR 0x1010). */
+static void
+ssl3_Ja4MaybeOverrideGrease(sslSocket *ss, const ssl3Ja4SlimConfig *cfg)
+{
+    PRUint8 nibble;
+    PRUint16 slot;
+    size_t i;
+
+    if (!cfg || !cfg->greaseValueSet) {
+        return;
+    }
+    if (!ss->opt.enableGrease || !ss->ssl3.hs.grease) {
+        return;
+    }
+
+    nibble = (PRUint8)(((cfg->greaseValue & 0xf0u) | 0x0au) & 0xffu);
+    slot = (PRUint16)(((PRUint16)nibble << 8) | nibble);
+
+    for (i = 0; i < PR_ARRAY_SIZE(ss->ssl3.hs.grease->idx); ++i) {
+        ss->ssl3.hs.grease->idx[i] = slot;
+    }
+    if (ss->ssl3.hs.grease->idx[grease_extension1] ==
+        ss->ssl3.hs.grease->idx[grease_extension2]) {
+        ss->ssl3.hs.grease->idx[grease_extension2] ^= 0x1010;
+    }
+    ss->ssl3.hs.grease->pskKem = (PRUint8)(0x0b + ((nibble >> 5) * 0x1f));
+}
+
+static PRBool
+ssl3_Ja4LoadConfigFromEnv(ssl3Ja4SlimConfig *cfg)
+{
+    const char *path = getenv("NSS_JA4_CONFIG");
+    if (!path || !*path) {
+        return PR_FALSE;
+    }
+    return ssl3_Ja4LoadConfig(path, cfg);
+}
+
+/* JA4 cfg active for the in-flight ClientHello. Set by ssl3_SendClientHello
+ * after env-load, cleared on exit. Read by ssl3_AppendCipherSuites (and W2
+ * synthetic-extension injection) to bypass NSS' table-bound emission for
+ * EXACT-mode raw lying. The pointer references caller-owned stack memory
+ * inside ssl3_SendClientHello — valid for the only callsite that reads it. */
+static const ssl3Ja4SlimConfig *s_ja4ActiveConfig = NULL;
+
+static void
+ssl3_Ja4SetActiveConfig(const ssl3Ja4SlimConfig *cfg)
+{
+    s_ja4ActiveConfig = cfg;
+}
+
+static const ssl3Ja4SlimConfig *
+ssl3_Ja4GetActiveConfig(void)
+{
+    return s_ja4ActiveConfig;
+}
+
+static PRUint32
+ssl3_Ja4CollectMismatchMask(sslSocket *ss, const ssl3Ja4SlimConfig *cfg,
+                            const sslBuffer *extensionBuf)
+{
+    PRUint16 effectiveCiphers[ssl_V3_SUITES_IMPLEMENTED];
+    PRUint16 effectiveExtensions[SSL3_JA4_CFG_MAX_LIST];
+    PRUint16 effectiveSupportedVersions[SSL3_JA4_CFG_MAX_LIST];
+    PRUint16 effectiveSupportedGroups[SSL3_JA4_CFG_MAX_LIST];
+    PRUint16 effectiveKeyShareGroups[SSL3_JA4_CFG_MAX_LIST];
+    PRUint8 effectivePskModes[SSL3_JA4_CFG_MAX_LIST];
+    unsigned int effectiveCipherCount = 0;
+    unsigned int effectiveExtensionCount = 0;
+    unsigned int effectiveSupportedVersionCount = 0;
+    unsigned int effectiveSupportedGroupCount = 0;
+    unsigned int effectiveKeyShareGroupCount = 0;
+    unsigned int effectivePskModeCount = 0;
+    PRUint32 mismatchMask = 0;
+
+    if (cfg->hasCipherSuites &&
+        cfg->hasCipherMode &&
+        cfg->cipherMode == ssl3Ja4CipherModeExact &&
+        ssl3_Ja4CollectEffectiveCipherSuites(ss, effectiveCiphers,
+                                             PR_ARRAY_SIZE(effectiveCiphers),
+                                             &effectiveCipherCount)) {
+        if (!ssl3_Ja4CompareU16Lists((const PRUint16 *)cfg->cipherSuites,
+                                     cfg->cipherSuiteCount, effectiveCiphers,
+                                     effectiveCipherCount)) {
+            mismatchMask |= ssl3Ja4MismatchCipherSuites;
+        }
+    } else if (cfg->hasCipherSuites &&
+               cfg->hasCipherMode &&
+               cfg->cipherMode == ssl3Ja4CipherModeExact) {
+        mismatchMask |= ssl3Ja4MismatchCipherSuites;
+    }
+
+    if (cfg->hasAlpn) {
+        if ((cfg->alpnLen != ss->opt.nextProtoNego.len) ||
+            PORT_Memcmp(cfg->alpn, ss->opt.nextProtoNego.data, cfg->alpnLen)) {
+            mismatchMask |= ssl3Ja4MismatchAlpn;
+        }
+    }
+
+    if (cfg->hasSignatureSchemes) {
+        if (!ssl3_Ja4CompareU16Lists((const PRUint16 *)cfg->signatureSchemes,
+                                     cfg->signatureSchemeCount,
+                                     (const PRUint16 *)ss->ssl3.signatureSchemes,
+                                     ss->ssl3.signatureSchemeCount)) {
+            mismatchMask |= ssl3Ja4MismatchSignatureSchemes;
+        }
+    }
+
+    if (cfg->hasExtensionOrder &&
+        ssl3_Ja4UseExtensionModeExact(cfg) &&
+        ssl3_Ja4CollectEffectiveExtensionTypes(extensionBuf, effectiveExtensions,
+                                               PR_ARRAY_SIZE(effectiveExtensions),
+                                               &effectiveExtensionCount)) {
+        if (!ssl3_Ja4CompareU16Lists(cfg->extensions, cfg->extensionCount,
+                                     effectiveExtensions,
+                                     effectiveExtensionCount)) {
+            mismatchMask |= ssl3Ja4MismatchExtensions;
+        }
+    } else if (cfg->hasExtensionOrder &&
+               ssl3_Ja4UseExtensionModeExact(cfg)) {
+        mismatchMask |= ssl3Ja4MismatchExtensions;
+    }
+
+    /* Phase 2: any explicitly-requested or auto-injected extension id that
+     * does not show up in the final ClientHello sets the schema-defined
+     * MissingExtension bit. This complements the strict order-match check
+     * above (which fires on order/membership differences). */
+    if (cfg->hasExtensionOrder &&
+        ssl3_Ja4CollectEffectiveExtensionTypes(extensionBuf, effectiveExtensions,
+                                               PR_ARRAY_SIZE(effectiveExtensions),
+                                               &effectiveExtensionCount)) {
+        unsigned int ri;
+        for (ri = 0; ri < cfg->extensionCount; ++ri) {
+            unsigned int fi;
+            PRBool found = PR_FALSE;
+            for (fi = 0; fi < effectiveExtensionCount; ++fi) {
+                if (effectiveExtensions[fi] == cfg->extensions[ri]) {
+                    found = PR_TRUE;
+                    break;
+                }
+            }
+            if (!found) {
+                mismatchMask |= ssl3Ja4MismatchMissingExtension;
+                break;
+            }
+        }
+    } else if (cfg->hasExtensionOrder && cfg->extensionCount) {
+        mismatchMask |= ssl3Ja4MismatchMissingExtension;
+    }
+
+    if (cfg->hasSupportedVersions &&
+        ssl3_Ja4CollectSupportedVersions(extensionBuf, effectiveSupportedVersions,
+                                         PR_ARRAY_SIZE(effectiveSupportedVersions),
+                                         &effectiveSupportedVersionCount)) {
+        if (!ssl3_Ja4CompareU16Lists(cfg->supportedVersions,
+                                     cfg->supportedVersionCount,
+                                     effectiveSupportedVersions,
+                                     effectiveSupportedVersionCount)) {
+            mismatchMask |= ssl3Ja4MismatchSupportedVersions;
+        }
+    } else if (cfg->hasSupportedVersions) {
+        mismatchMask |= ssl3Ja4MismatchSupportedVersions;
+    }
+
+    if (cfg->hasSupportedGroups &&
+        ssl3_Ja4CollectSupportedGroups(extensionBuf, effectiveSupportedGroups,
+                                       PR_ARRAY_SIZE(effectiveSupportedGroups),
+                                       &effectiveSupportedGroupCount)) {
+        if (!ssl3_Ja4CompareU16Lists(cfg->supportedGroups,
+                                     cfg->supportedGroupCount,
+                                     effectiveSupportedGroups,
+                                     effectiveSupportedGroupCount)) {
+            mismatchMask |= ssl3Ja4MismatchSupportedGroups;
+        }
+    } else if (cfg->hasSupportedGroups) {
+        mismatchMask |= ssl3Ja4MismatchSupportedGroups;
+    }
+
+    if (cfg->hasKeyShareGroups &&
+        ssl3_Ja4CollectKeyShareGroups(extensionBuf, effectiveKeyShareGroups,
+                                      PR_ARRAY_SIZE(effectiveKeyShareGroups),
+                                      &effectiveKeyShareGroupCount)) {
+        if (!ssl3_Ja4CompareU16Lists(cfg->keyShareGroups,
+                                     cfg->keyShareGroupCount,
+                                     effectiveKeyShareGroups,
+                                     effectiveKeyShareGroupCount)) {
+            mismatchMask |= ssl3Ja4MismatchKeyShareGroups;
+        }
+    } else if (cfg->hasKeyShareGroups) {
+        mismatchMask |= ssl3Ja4MismatchKeyShareGroups;
+    }
+
+    if (cfg->hasPskKeyExchangeModes &&
+        ssl3_Ja4CollectPskKeyExchangeModes(extensionBuf, effectivePskModes,
+                                           PR_ARRAY_SIZE(effectivePskModes),
+                                           &effectivePskModeCount)) {
+        if (!ssl3_Ja4CompareU8Lists(cfg->pskKeyExchangeModes,
+                                    cfg->pskKeyExchangeModeCount,
+                                    effectivePskModes,
+                                    effectivePskModeCount)) {
+            mismatchMask |= ssl3Ja4MismatchPskKeyExchangeModes;
+        }
+    } else if (cfg->hasPskKeyExchangeModes) {
+        mismatchMask |= ssl3Ja4MismatchPskKeyExchangeModes;
+    }
+
+    return mismatchMask;
+}
+
+static SECStatus
+ssl3_Ja4EnforceStrictConfig(sslSocket *ss, const ssl3Ja4SlimConfig *cfg,
+                            const sslBuffer *extensionBuf,
+                            PRUint32 *mismatchMask)
+{
+    PRUint32 mask = ssl3_Ja4CollectMismatchMask(ss, cfg, extensionBuf);
+
+    if (mismatchMask) {
+        *mismatchMask = mask;
+    }
+
+    if (!cfg->strict) {
+        return SECSuccess;
+    }
+
+    if (mask) {
+        PORT_SetError(SEC_ERROR_INVALID_ARGS);
+        return SECFailure;
+    }
+
+    return SECSuccess;
+}
+
+static void
+ssl3_Ja4DumpAlpn(FILE *fp, const SECItem *alpn)
+{
+    unsigned int offset = 0;
+    PRBool first = PR_TRUE;
+
+    while (offset < alpn->len) {
+        unsigned int len = alpn->data[offset];
+        if (len == 0 || (offset + 1 + len) > alpn->len) {
+            break;
+        }
+        if (!first) {
+            fputc(',', fp);
+        }
+        fwrite(alpn->data + offset + 1, 1, len, fp);
+        first = PR_FALSE;
+        offset += 1 + len;
+    }
+}
+
+static void
+ssl3_Ja4MaybeDumpConfig(sslSocket *ss, const ssl3Ja4SlimConfig *cfg,
+                        PRUint32 mismatchMask,
+                        const sslBuffer *extensionBuf)
+{
+    ssl3Ja4ExtensionView parsed[SSL3_JA4_CFG_MAX_LIST];
+    PRUint16 effectiveCiphers[ssl_V3_SUITES_IMPLEMENTED];
+    PRUint16 effectiveSupportedVersions[SSL3_JA4_CFG_MAX_LIST];
+    PRUint16 effectiveSupportedGroups[SSL3_JA4_CFG_MAX_LIST];
+    PRUint16 effectiveKeyShareGroups[SSL3_JA4_CFG_MAX_LIST];
+    PRUint16 effectiveExtensionTypes[SSL3_JA4_CFG_MAX_LIST];
+    PRUint8 effectivePskModes[SSL3_JA4_CFG_MAX_LIST];
+    SECItem requestedAlpn = { siBuffer, NULL, 0 };
+    unsigned int effectiveCipherCount = 0;
+    unsigned int effectiveSupportedVersionCount = 0;
+    unsigned int effectiveSupportedGroupCount = 0;
+    unsigned int effectiveKeyShareGroupCount = 0;
+    unsigned int effectiveExtensionCount = 0;
+    unsigned int effectivePskModeCount = 0;
+    unsigned int parsedCount = 0;
+    PRUint32 effectiveMask = (cfg ? cfg->mismatchMask : 0u) | mismatchMask;
+    PRBool hasParsedExtensions = PR_FALSE;
+    PRBool hasSni = PR_FALSE;
+    const char *path = getenv("NSS_JA4_DUMP");
+    FILE *fp;
+    unsigned int i;
+
+    if (!path || !*path) {
+        return;
+    }
+
+    fp = fopen(path, "w");
+    if (!fp) {
+        return;
+    }
+
+    if (extensionBuf) {
+        hasParsedExtensions = ssl3_Ja4ParseExtensionBuffer(
+            extensionBuf, parsed, PR_ARRAY_SIZE(parsed), &parsedCount);
+    }
+    (void)ssl3_Ja4CollectEffectiveCipherSuites(ss, effectiveCiphers,
+                                               PR_ARRAY_SIZE(effectiveCiphers),
+                                               &effectiveCipherCount);
+    (void)ssl3_Ja4CollectSupportedVersions(extensionBuf, effectiveSupportedVersions,
+                                           PR_ARRAY_SIZE(effectiveSupportedVersions),
+                                           &effectiveSupportedVersionCount);
+    (void)ssl3_Ja4CollectSupportedGroups(extensionBuf, effectiveSupportedGroups,
+                                         PR_ARRAY_SIZE(effectiveSupportedGroups),
+                                         &effectiveSupportedGroupCount);
+    (void)ssl3_Ja4CollectKeyShareGroups(extensionBuf, effectiveKeyShareGroups,
+                                        PR_ARRAY_SIZE(effectiveKeyShareGroups),
+                                        &effectiveKeyShareGroupCount);
+    (void)ssl3_Ja4CollectPskKeyExchangeModes(extensionBuf, effectivePskModes,
+                                             PR_ARRAY_SIZE(effectivePskModes),
+                                             &effectivePskModeCount);
+    (void)ssl3_Ja4CollectEffectiveExtensionTypes(extensionBuf,
+                                                 effectiveExtensionTypes,
+                                                 PR_ARRAY_SIZE(effectiveExtensionTypes),
+                                                 &effectiveExtensionCount);
+
+    if (hasParsedExtensions) {
+        for (i = 0; i < parsedCount; ++i) {
+            if (parsed[i].type == ssl_server_name_xtn) {
+                hasSni = PR_TRUE;
+                break;
+            }
+        }
+    } else {
+        for (i = 0; i < ss->xtnData.numAdvertised; ++i) {
+            if (ss->xtnData.advertised[i] == ssl_server_name_xtn) {
+                hasSni = PR_TRUE;
+                break;
+            }
+        }
+    }
+
+    fprintf(fp, "active=%u\n", cfg ? 1u : 0u);
+    fprintf(fp, "apply_ok=%u\n", effectiveMask ? 0u : 1u);
+    fprintf(fp, "mismatch_mask=%u\n", (unsigned int)effectiveMask);
+    fprintf(fp, "effective_tls_min=%u\n", (unsigned int)ss->vrange.min);
+    fprintf(fp, "effective_tls_max=%u\n", (unsigned int)ss->vrange.max);
+    fprintf(fp, "strict=%u\n", (cfg && cfg->strict) ? 1u : 0u);
+    fprintf(fp, "sni_mode=%s\n",
+            (cfg && cfg->hasSniMode)
+                ? ssl3_Ja4SniModeStr(cfg->sniMode)
+                : (hasSni ? "present" : "none"));
+    fprintf(fp, "enable_grease=%u\n", ss->opt.enableGrease ? 1u : 0u);
+    fprintf(fp, "enable_ch_xtn_permutation=%u\n",
+            ss->opt.enableChXtnPermutation ? 1u : 0u);
+    if (cfg && cfg->greaseValueSet) {
+        fprintf(fp, "grease_value=%u\n", (unsigned int)cfg->greaseValue);
