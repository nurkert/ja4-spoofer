+static void
+ssl3_Ja4DumpU16List(FILE *fp, const PRUint16 *values, unsigned int count)
+{
+    unsigned int i;
+
+    for (i = 0; i < count; ++i) {
+        if (i) {
+            fputc(',', fp);
+        }
+        fprintf(fp, "%u", (unsigned int)values[i]);
+    }
+}
+
+static void
+ssl3_Ja4DumpRequestedCipherState(FILE *fp, const sslSocket *ss,
+                                 const ssl3Ja4SlimConfig *cfg)
+{
+    unsigned int i;
+
+    if (!cfg || !cfg->hasCipherSuites) {
+        return;
+    }
+
+    for (i = 0; i < cfg->cipherSuiteCount; ++i) {
+        const ssl3CipherSuiteCfg *suite =
+            ssl_LookupCipherSuiteCfg(cfg->cipherSuites[i], ss->cipherSuites);
+        if (!suite) {
+            fprintf(fp, "lib_cipher_state_%u=missing\n",
+                    (unsigned int)cfg->cipherSuites[i]);
+            continue;
+        }
+        fprintf(fp, "lib_cipher_state_%u=enabled:%u,policy:%u,present:%u\n",
+                (unsigned int)cfg->cipherSuites[i],
+                suite->enabled ? 1u : 0u,
+                (unsigned int)suite->policy,
+                suite->isPresent ? 1u : 0u);
+    }
+}
+
+static PRBool
+ssl3_Ja4ParseExtensionBuffer(const sslBuffer *extensionBuf,
+                             ssl3Ja4ExtensionView *out,
+                             unsigned int maxCount,
+                             unsigned int *outCount)
+{
+    unsigned int offset = 0;
+    unsigned int count = 0;
+
+    *outCount = 0;
+
+    while (offset < extensionBuf->len) {
+        unsigned int dataLen;
+        unsigned int totalLen;
+
+        if ((offset + 4) > extensionBuf->len || count >= maxCount) {
+            return PR_FALSE;
+        }
+
+        dataLen = (((unsigned int)extensionBuf->buf[offset + 2]) << 8) |
+                  (unsigned int)extensionBuf->buf[offset + 3];
+        totalLen = 4 + dataLen;
+        if ((offset + totalLen) > extensionBuf->len) {
+            return PR_FALSE;
+        }
+
+        out[count].type = (((PRUint16)extensionBuf->buf[offset]) << 8) |
+                          (PRUint16)extensionBuf->buf[offset + 1];
+        out[count].offset = offset;
+        out[count].length = totalLen;
+        ++count;
+        offset += totalLen;
+    }
+
+    *outCount = count;
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4FindExtension(const sslBuffer *extensionBuf, PRUint16 type,
+                      ssl3Ja4ExtensionView *view)
+{
+    ssl3Ja4ExtensionView parsed[SSL3_JA4_CFG_MAX_LIST];
+    unsigned int parsedCount = 0;
+    unsigned int i;
+
+    if (!ssl3_Ja4ParseExtensionBuffer(extensionBuf, parsed, PR_ARRAY_SIZE(parsed),
+                                      &parsedCount)) {
+        return PR_FALSE;
+    }
+
+    for (i = 0; i < parsedCount; ++i) {
+        if (parsed[i].type == type) {
+            *view = parsed[i];
+            return PR_TRUE;
+        }
+    }
+
+    return PR_FALSE;
+}
+
+static SECStatus
+ssl3_Ja4ReplaceExtensionBody(sslBuffer *extensionBuf, PRUint16 type,
+                             const PRUint8 *body, unsigned int bodyLen)
+{
+    ssl3Ja4ExtensionView parsed[SSL3_JA4_CFG_MAX_LIST];
+    sslBuffer rewritten = SSL_BUFFER_EMPTY;
+    unsigned int parsedCount = 0;
+    unsigned int i;
+    PRBool replaced = PR_FALSE;
+
+    if (!ssl3_Ja4ParseExtensionBuffer(extensionBuf, parsed, PR_ARRAY_SIZE(parsed),
+                                      &parsedCount)) {
+        return SECFailure;
+    }
+
+    for (i = 0; i < parsedCount; ++i) {
+        if (parsed[i].type == type) {
+            if (sslBuffer_AppendNumber(&rewritten, type, 2) != SECSuccess ||
+                sslBuffer_AppendNumber(&rewritten, bodyLen, 2) != SECSuccess ||
+                sslBuffer_Append(&rewritten, body, bodyLen) != SECSuccess) {
+                goto loser;
+            }
+            replaced = PR_TRUE;
+            continue;
+        }
+
+        if (sslBuffer_Append(&rewritten, extensionBuf->buf + parsed[i].offset,
+                             parsed[i].length) != SECSuccess) {
+            goto loser;
+        }
+    }
+
+    if (!replaced) {
+        goto loser;
+    }
+
+    sslBuffer_Clear(extensionBuf);
+    *extensionBuf = rewritten;
+    return SECSuccess;
+
+loser:
+    sslBuffer_Clear(&rewritten);
+    return SECFailure;
+}
+
+static PRBool
+ssl3_Ja4ConsumeU16List(const PRUint8 *data, unsigned int dataLen,
+                       unsigned int headerLen, PRUint16 *out,
+                       unsigned int maxCount, unsigned int *outCount)
+{
+    unsigned int payloadLen = 0;
+    unsigned int offset = 0;
+
+    *outCount = 0;
+
+    if (headerLen == 1) {
+        if (dataLen < 1) {
+            return PR_FALSE;
+        }
+        payloadLen = data[0];
+        offset = 1;
+    } else if (headerLen == 2) {
+        if (dataLen < 2) {
+            return PR_FALSE;
+        }
+        payloadLen = (((unsigned int)data[0]) << 8) | data[1];
+        offset = 2;
+    } else {
+        return PR_FALSE;
+    }
+
+    if (payloadLen + offset != dataLen || (payloadLen & 1)) {
+        return PR_FALSE;
+    }
+
+    while (offset < dataLen) {
+        if (*outCount >= maxCount) {
+            return PR_FALSE;
+        }
+        out[(*outCount)++] = (((PRUint16)data[offset]) << 8) | data[offset + 1];
+        offset += 2;
+    }
+
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4CollectSupportedVersions(const sslBuffer *extensionBuf, PRUint16 *out,
+                                 unsigned int maxCount, unsigned int *outCount)
+{
+    ssl3Ja4ExtensionView view;
+
+    if (!ssl3_Ja4FindExtension(extensionBuf, ssl_tls13_supported_versions_xtn,
+                               &view) ||
+        view.length < 5) {
+        return PR_FALSE;
+    }
+
+    return ssl3_Ja4ConsumeU16List(extensionBuf->buf + view.offset + 4,
+                                  view.length - 4, 1,
+                                  out, maxCount, outCount);
+}
+
+static PRBool
+ssl3_Ja4CollectSupportedGroups(const sslBuffer *extensionBuf, PRUint16 *out,
+                               unsigned int maxCount, unsigned int *outCount)
+{
+    ssl3Ja4ExtensionView view;
+
+    if (!ssl3_Ja4FindExtension(extensionBuf, ssl_supported_groups_xtn, &view) ||
+        view.length < 6) {
+        return PR_FALSE;
+    }
+
+    return ssl3_Ja4ConsumeU16List(extensionBuf->buf + view.offset + 4,
+                                  view.length - 4, 2,
+                                  out, maxCount, outCount);
+}
+
+static PRBool
+ssl3_Ja4CollectPskKeyExchangeModes(const sslBuffer *extensionBuf, PRUint8 *out,
+                                   unsigned int maxCount, unsigned int *outCount)
+{
+    ssl3Ja4ExtensionView view;
+    const PRUint8 *data;
+    unsigned int i;
+    unsigned int payloadLen;
+
+    *outCount = 0;
+
+    if (!ssl3_Ja4FindExtension(extensionBuf, ssl_tls13_psk_key_exchange_modes_xtn,
+                               &view) ||
+        view.length < 5) {
+        return PR_FALSE;
+    }
+
+    data = extensionBuf->buf + view.offset + 4;
+    payloadLen = data[0];
+    if (payloadLen + 1 != view.length - 4 || payloadLen > maxCount) {
+        return PR_FALSE;
+    }
+
+    for (i = 0; i < payloadLen; ++i) {
+        out[i] = data[i + 1];
+    }
+    *outCount = payloadLen;
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4CollectKeyShareGroups(const sslBuffer *extensionBuf, PRUint16 *out,
+                              unsigned int maxCount, unsigned int *outCount)
+{
+    ssl3Ja4ExtensionView view;
+    const PRUint8 *data;
+    unsigned int dataLen;
+    unsigned int payloadLen;
+    unsigned int offset;
+
+    *outCount = 0;
+
+    if (!ssl3_Ja4FindExtension(extensionBuf, ssl_tls13_key_share_xtn, &view) ||
+        view.length < 6) {
+        return PR_FALSE;
+    }
+
+    data = extensionBuf->buf + view.offset + 4;
+    dataLen = view.length - 4;
+    payloadLen = (((unsigned int)data[0]) << 8) | data[1];
+    if (payloadLen + 2 != dataLen) {
+        return PR_FALSE;
+    }
+
+    offset = 2;
+    while (offset < dataLen) {
+        unsigned int shareLen;
+        if ((offset + 4) > dataLen || *outCount >= maxCount) {
+            return PR_FALSE;
+        }
+        out[(*outCount)++] = (((PRUint16)data[offset]) << 8) | data[offset + 1];
+        shareLen = (((unsigned int)data[offset + 2]) << 8) | data[offset + 3];
+        offset += 4;
+        if ((offset + shareLen) > dataLen) {
+            return PR_FALSE;
+        }
+        offset += shareLen;
+    }
+
+    return PR_TRUE;
+}
+
+static PRBool
+ssl3_Ja4CompareU8Lists(const PRUint8 *left, unsigned int leftCount,
+                       const PRUint8 *right, unsigned int rightCount)
+{
+    unsigned int i;
+
+    if (leftCount != rightCount) {
+        return PR_FALSE;
+    }
+    for (i = 0; i < leftCount; ++i) {
+        if (left[i] != right[i]) {
+            return PR_FALSE;
+        }
+    }
+    return PR_TRUE;
+}
